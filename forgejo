# --- RELEASE COMMANDS ---

cmd_release() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo release <list|create|view|edit|delete|upload-asset|asset> [args]" >&2
        exit 1
    fi

    local action="$1"
    shift

    case "$action" in
        list)   release_list "$@" ;;
        create) release_create "$@" ;;
        view)   release_view "$@" ;;
        edit)   release_edit "$@" ;;
        delete) release_delete "$@" ;;
        upload-asset) release_upload_asset "$@" ;;
        asset)  cmd_release_asset "$@" ;;
        *)      echo "Unknown release action: $action" >&2; exit 1 ;;
    esac
}

release_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo release list <owner/repo>" >&2
        exit 1
    fi

    local repo="$1"
    local result
    result=$(api_call GET "repos/$repo/releases?limit=20")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
            echo "No releases found."
        else
            echo "$result" | jq -r '
                ["TAG","TITLE","DRAFT","PRERELEASE","PUBLISHED"],
                (.[] | [
                    .tag_name,
                    .name[:40],
                    (if .draft then "yes" else "no" end),
                    (if .prerelease then "yes" else "no" end),
                    (.published_at // .created_at)[:10]
                ])
                | @tsv
            ' | column -t -s $'\t'
        fi
    fi
}

release_create() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo release create <owner/repo> --tag=X --title=X [--body=X] [--draft] [--prerelease]" >&2
        exit 1
    fi

    local repo="$1"
    shift

    local tag title body_text
    tag=$(get_flag "--tag" "$@" 2>/dev/null) || { echo "Missing --tag" >&2; exit 1; }
    title=$(get_flag "--title" "$@" 2>/dev/null) || { echo "Missing --title" >&2; exit 1; }
    body_text=$(get_flag "--body" "$@" 2>/dev/null) || body_text=""

    local draft="false"
    local prerelease="false"
    has_flag "--draft" "$@" && draft="true"
    has_flag "--prerelease" "$@" && prerelease="true"

    local body
    body=$(jq -n \
        --arg tag "$tag" \
        --arg name "$title" \
        --arg body "$body_text" \
        --argjson draft "$draft" \
        --argjson prerelease "$prerelease" \
        '{tag_name: $tag, name: $name, body: $body, draft: $draft, prerelease: $prerelease}')

    local result
    result=$(api_call POST "repos/$repo/releases" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created release: \(.name) (\(.tag_name))\nURL: \(.html_url // "-")"'
    fi
}

# Resolves a release ID from a tag name. Exits non-zero (via api_call) if the
# tag has no release. Used by edit, upload-asset, asset list, asset delete.
resolve_release_id() {
    local repo="$1"
    local tag="$2"
    api_call GET "repos/$repo/releases/tags/$tag" | jq -r '.id'
}

release_view() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo release view <owner/repo> <tag>" >&2
        exit 1
    fi

    local repo="$1"
    local tag="$2"
    local result
    result=$(api_call GET "repos/$repo/releases/tags/$tag")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            "Tag:        \(.tag_name)",
            "Title:      \(.name)",
            "Draft:      \(if .draft then "yes" else "no" end)",
            "Prerelease: \(if .prerelease then "yes" else "no" end)",
            "Target:     \(.target_commitish)",
            "Published:  \(.published_at // .created_at)",
            "Author:     \(.author.login // "-")",
            "URL:        \(.html_url // "-")",
            "",
            (.body // "(no body)")
        '
    fi
}

release_edit() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo release edit <owner/repo> <tag> [--title=X] [--body=X] [--draft|--no-draft] [--prerelease|--no-prerelease]" >&2
        exit 1
    fi

    local repo="$1"
    local tag="$2"
    shift 2

    local title body_text
    title=$(get_flag "--title" "$@" 2>/dev/null) || title=""
    body_text=$(get_flag "--body" "$@" 2>/dev/null) || body_text=""

    local draft=""
    if has_flag "--draft" "$@" && has_flag "--no-draft" "$@"; then
        echo "Provide --draft OR --no-draft, not both" >&2; exit 1
    fi
    has_flag "--draft" "$@" && draft="true"
    has_flag "--no-draft" "$@" && draft="false"

    local prerelease=""
    if has_flag "--prerelease" "$@" && has_flag "--no-prerelease" "$@"; then
        echo "Provide --prerelease OR --no-prerelease, not both" >&2; exit 1
    fi
    has_flag "--prerelease" "$@" && prerelease="true"
    has_flag "--no-prerelease" "$@" && prerelease="false"

    if [[ -z "$title" && -z "$body_text" && -z "$draft" && -z "$prerelease" ]]; then
        echo "Nothing to edit (supply --title, --body, --draft/--no-draft, or --prerelease/--no-prerelease)" >&2
        exit 1
    fi

    local release_id
    release_id=$(resolve_release_id "$repo" "$tag")

    local body
    body=$(jq -n \
        --arg title "$title" \
        --arg body "$body_text" \
        --arg draft "$draft" \
        --arg prerelease "$prerelease" \
        '{}
          + (if $title       != "" then {name: $title}                  else {} end)
          + (if $body        != "" then {body: $body}                   else {} end)
          + (if $draft       != "" then {draft: ($draft == "true")}     else {} end)
          + (if $prerelease  != "" then {prerelease: ($prerelease == "true")} else {} end)')

    local result
    result=$(api_call PATCH "repos/$repo/releases/$release_id" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Updated release: \(.name) (\(.tag_name))\nURL: \(.html_url // "-")"'
    fi
}

release_delete() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo release delete <owner/repo> <tag> [--yes]" >&2
        exit 1
    fi

    local repo="$1"
    local tag="$2"
    shift 2

    confirm_delete "release" "$tag" "$@"

    api_call DELETE "repos/$repo/releases/tags/$tag" >/dev/null
    echo "Deleted release: $tag"
}

release_upload_asset() {
    if [[ $# -lt 3 ]]; then
        echo "Usage: forgejo release upload-asset <owner/repo> <tag> <file>..." >&2
        exit 1
    fi

    local repo="$1"
    local tag="$2"
    shift 2

    # Validate every file up-front so we don't half-upload before discovering
    # a typo in arg N.
    local f
    for f in "$@"; do
        if [[ ! -f "$f" ]]; then
            echo "Not a regular file: $f" >&2
            exit 1
        fi
    done

    local release_id
    release_id=$(resolve_release_id "$repo" "$tag")

    local url="${FORGEJO_URL}/api/v1/repos/$repo/releases/$release_id/assets"
    local uploaded=()

    for f in "$@"; do
        local tmp status
        tmp=$(mktemp)
        status=$(curl -s \
            -X POST \
            -H "Authorization: token $FORGEJO_TOKEN" \
            -H "Accept: application/json" \
            -F "attachment=@$f" \
            -w '%{http_code}' \
            -o "$tmp" \
            "$url")

        if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
            echo "Upload failed for $f (HTTP $status):" >&2
            jq -r '.message // .error // .' "$tmp" >&2 2>/dev/null || cat "$tmp" >&2
            rm -f "$tmp"
            if [[ ${#uploaded[@]} -gt 0 ]]; then
                echo "Files uploaded before failure: ${uploaded[*]}" >&2
            fi
            exit 1
        fi

        local asset_id
        asset_id=$(jq -r '.id' "$tmp")
        echo "Uploaded: $(basename "$f") (id=$asset_id)"
        uploaded+=("$(basename "$f")")
        rm -f "$tmp"
    done
}

cmd_release_asset() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo release asset <list|delete> [args]" >&2
        exit 1
    fi

    local action="$1"
    shift

    case "$action" in
        list)   release_asset_list "$@" ;;
        delete) release_asset_delete "$@" ;;
        *)      echo "Unknown release asset action: $action" >&2; exit 1 ;;
    esac
}

release_asset_list() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo release asset list <owner/repo> <tag>" >&2
        exit 1
    fi

    local repo="$1"
    local tag="$2"
    local release_id
    release_id=$(resolve_release_id "$repo" "$tag")

    local result
    result=$(api_call GET "repos/$repo/releases/$release_id/assets")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
            echo "No assets found."
        else
            echo "$result" | jq -r '
                ["ID","NAME","SIZE","DOWNLOADS","CREATED"],
                (.[] | [
                    .id,
                    .name,
                    .size,
                    .download_count,
                    (.created_at[:10])
                ])
                | @tsv
            ' | column -t -s $'\t'
        fi
    fi
}

release_asset_delete() {
    if [[ $# -lt 3 ]]; then
        echo "Usage: forgejo release asset delete <owner/repo> <tag> <asset_id> [--yes]" >&2
        exit 1
    fi

    local repo="$1"
    local tag="$2"
    local asset_id="$3"
    shift 3

    confirm_delete "asset" "#$asset_id" "$@"

    local release_id
    release_id=$(resolve_release_id "$repo" "$tag")

    api_call DELETE "repos/$repo/releases/$release_id/assets/$asset_id" >/dev/null
    echo "Deleted asset #$asset_id"
}

# --- WIKI COMMANDS ---

# URL-encodes a single path segment (wiki page titles may contain spaces and
# other unsafe characters). Prints the encoded value to stdout.
wiki_encode_page() {
    printf '%s' "$1" | jq -sRr @uri
}

# Resolves wiki page content from --content= or --file= (in that precedence).
# --file=- reads from stdin. Prints the resolved content to stdout. Return
# codes: 0 = resolved, 1 = no source supplied, 2 = --file path is not a
# regular file (message already emitted to stderr). There is no implicit
# stdin: piping requires an explicit --file=-.
#
# Usage:
#   rc=0; content=$(wiki_resolve_content "$@" && printf 'x') || rc=$?
wiki_resolve_content() {
    local content file
    local rc=0
    content=$(get_flag "--content" "$@" 2>/dev/null && printf 'x') || rc=$?
    if [[ "$rc" -eq 0 ]]; then
        # get_flag echoes the value with one trailing newline; the 'x' sentinel
        # (only appended when get_flag succeeds, via &&) lets $(...) keep the
        # user's own trailing newlines. Strip the sentinel, then the single
        # newline echo added.
        content=${content%x}
        printf '%s' "${content%$'\n'}"
        return 0
    fi
    if file=$(get_flag "--file" "$@" 2>/dev/null); then
        if [[ "$file" == "-" ]]; then
            cat
            return 0
        fi
        if [[ ! -f "$file" ]]; then
            echo "Not a regular file: $file" >&2
            return 2
        fi
        cat "$file"
        return 0
    fi
    return 1
}

cmd_wiki() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_wiki_help
        exit 0
    fi

    local action="$1"
    shift

    case "$action" in
        list)      wiki_list "$@" ;;
        view)      wiki_view "$@" ;;
        create)    wiki_create "$@" ;;
        edit)      wiki_edit "$@" ;;
        delete)    wiki_delete "$@" ;;
        revisions) wiki_revisions "$@" ;;
        *)         echo "Unknown wiki action: $action" >&2; exit 1 ;;
    esac
}

show_wiki_help() {
    cat <<'EOF'
forgejo wiki — manage repository wiki pages

Usage:
  forgejo wiki list <owner/repo>
  forgejo wiki view <owner/repo> <page>
  forgejo wiki create <owner/repo> --title=X [--content=X|--file=path|--file=-] [--message=X]
  forgejo wiki edit <owner/repo> <page> [--title=X] [--content=X|--file=path|--file=-] [--message=X]
  forgejo wiki delete <owner/repo> <page> [--yes]
  forgejo wiki revisions <owner/repo> <page>

Content sources (create/edit), in precedence order:
  --content=TEXT    inline content
  --file=PATH       read content from a file
  --file=-          read content from stdin

Notes:
  - Page names may contain spaces; quote them (e.g. "Release Notes").
  - edit requires --title and/or a content source; with neither it errors.
  - --message sets the commit message; omitted uses the server default.

Global flags:
  --json   Output raw JSON instead of formatted columns
EOF
}

wiki_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo wiki list <owner/repo>" >&2
        exit 1
    fi

    local repo="$1"
    local result
    result=$(api_call GET "repos/$repo/wiki/pages?limit=50")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
            echo "No wiki pages found."
        else
            echo "$result" | jq -r '
                ["TITLE","UPDATED","AUTHOR"],
                (.[] | [
                    .title,
                    (.last_commit.author.date // "")[:10],
                    (.last_commit.author.name // "-")
                ])
                | @tsv
            ' | column -t -s $'\t'
        fi
    fi
}

wiki_view() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo wiki view <owner/repo> <page>" >&2
        exit 1
    fi

    local repo="$1"
    local page="$2"
    local page_enc
    page_enc=$(wiki_encode_page "$page")

    local result
    result=$(api_call GET "repos/$repo/wiki/page/$page_enc")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            "Title:    \(.title)",
            "Updated:  \(.last_commit.author.date // "-")",
            "Author:   \(.last_commit.author.name // "-")",
            "Commit:   \(.last_commit.sha // "-")",
            ""
        '
        # Content is base64-encoded; decode and print verbatim.
        echo "$result" | jq -r '.content_base64 // ""' | base64 -d
    fi
}

wiki_create() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo wiki create <owner/repo> --title=X [--content=X|--file=path|--file=-] [--message=X]" >&2
        exit 1
    fi

    local repo="$1"
    shift

    local title message content
    title=$(get_flag "--title" "$@" 2>/dev/null) || { echo "Missing --title" >&2; exit 1; }
    message=$(get_flag "--message" "$@" 2>/dev/null) || message=""

    # Capture with a sentinel so $(...) does not strip trailing newlines.
    # rc=2 means --file pointed at a non-regular file (already reported);
    # rc=1 means no content source was supplied.
    local rc=0
    content=$(wiki_resolve_content "$@" && printf 'x') || rc=$?
    if [[ "$rc" -eq 2 ]]; then
        exit 1
    elif [[ "$rc" -ne 0 ]]; then
        echo "No content supplied. Use --content=X, --file=path, or --file=- to read stdin (use --content='' for an empty page)." >&2
        exit 1
    fi
    content=${content%x}

    # base64 here is GNU coreutils (Linux target): -w0 encodes without
    # wrapping; -d decodes (see wiki_view).
    local content_b64
    content_b64=$(printf '%s' "$content" | base64 -w0)

    local body
    body=$(jq -n \
        --arg title "$title" \
        --arg content "$content_b64" \
        --arg message "$message" \
        '{title: $title, content_base64: $content}
          + (if $message != "" then {message: $message} else {} end)')

    local result
    result=$(api_call POST "repos/$repo/wiki/new" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created wiki page: \(.title)"'
    fi
}

wiki_edit() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo wiki edit <owner/repo> <page> [--title=X] [--content=X|--file=path|--file=-] [--message=X]" >&2
        exit 1
    fi

    local repo="$1"
    local page="$2"
    shift 2

    local title message
    title=$(get_flag "--title" "$@" 2>/dev/null) || title=""
    message=$(get_flag "--message" "$@" 2>/dev/null) || message=""

    # Resolve content only if a source was supplied; absent source leaves
    # content unchanged. Sentinel ('x') preserves trailing newlines. rc=2
    # means --file pointed at a non-regular file (already reported) → abort.
    local content="" have_content=0 rc=0
    content=$(wiki_resolve_content "$@" && printf 'x') || rc=$?
    if [[ "$rc" -eq 2 ]]; then
        exit 1
    elif [[ "$rc" -eq 0 ]]; then
        have_content=1
        content=${content%x}
    fi

    if [[ -z "$title" && "$have_content" -eq 0 ]]; then
        echo "Nothing to edit (supply --title and/or content via --content/--file)." >&2
        exit 1
    fi

    # Forgejo's wiki PATCH requires a title; omitting it renames the page to
    # "unnamed". When the user didn't pass --title, keep the current name.
    if [[ -z "$title" ]]; then
        title="$page"
    fi

    local page_enc
    page_enc=$(wiki_encode_page "$page")

    local content_b64
    if [[ "$have_content" -eq 1 ]]; then
        content_b64=$(printf '%s' "$content" | base64 -w0)
    else
        # Rename-only edit: Forgejo's PATCH blanks content when content_base64
        # is omitted, so fetch the current content and resend it unchanged.
        local current
        current=$(api_call GET "repos/$repo/wiki/page/$page_enc")
        content_b64=$(echo "$current" | jq -r '.content_base64 // ""')
    fi

    local body
    body=$(jq -n \
        --arg title "$title" \
        --arg content "$content_b64" \
        --arg message "$message" \
        '{title: $title, content_base64: $content}
          + (if $message != "" then {message: $message} else {} end)')

    local result
    result=$(api_call PATCH "repos/$repo/wiki/page/$page_enc" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Updated wiki page: \(.title)"'
    fi
}

wiki_delete() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo wiki delete <owner/repo> <page> [--yes]" >&2
        exit 1
    fi

    local repo="$1"
    local page="$2"
    shift 2

    confirm_delete "wiki page" "$page" "$@"

    local page_enc
    page_enc=$(wiki_encode_page "$page")

    api_call DELETE "repos/$repo/wiki/page/$page_enc" >/dev/null
    echo "Deleted wiki page: $page"
}

wiki_revisions() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo wiki revisions <owner/repo> <page>" >&2
        exit 1
    fi

    local repo="$1"
    local page="$2"
    local page_enc
    page_enc=$(wiki_encode_page "$page")

    local result
    result=$(api_call GET "repos/$repo/wiki/revisions/$page_enc")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e '(.commits // []) | length == 0' > /dev/null 2>&1; then
            echo "No revisions found."
        else
            echo "$result" | jq -r '
                ["SHA","DATE","AUTHOR","MESSAGE"],
                (.commits[] | [
                    ((.sha // "") | .[:10]),
                    (.author.date // "")[:10],
                    (.author.name // "-"),
                    ((.message // "") | gsub("\n";" "))[:50]
                ])
                | @tsv
            ' | column -t -s $'\t'
        fi
    fi
}

# --- API PASSTHROUGH ---

# Accumulates a JSON body and/or URL query string from -f / -F / --input args.
# Writes results to globals:
#   API_BODY  - JSON string (empty if no body fields)
#   API_QUERY - URL-encoded query string without leading '?' (empty if no fields)
# For GET/HEAD methods, fields go into API_QUERY. For others, into API_BODY.
#
# -f key=value      string field (always JSON string)
# -F key=value      typed field: true/false -> bool, integers -> number,
#                   @filename -> file contents (string), else string
# -f key[]=value    array field (repeatable; accumulates)
# --input -         read raw JSON body from stdin (overrides any -f/-F body)
build_api_body() {
    local method="$1"; shift
    API_BODY=""
    API_QUERY=""

    local for_query=0
    [[ "$method" == "GET" || "$method" == "HEAD" ]] && for_query=1

    local -a query_pairs=()
    local body_acc='{}'

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --input)
                shift
                if [[ "${1:-}" != "-" ]]; then
                    echo "forgejo api: --input requires '-' (stdin) in v1" >&2
                    exit 1
                fi
                API_BODY=$(cat)
                shift
                ;;
            -f|-F)
                local typed=0
                [[ "$1" == "-F" ]] && typed=1
                shift
                if [[ $# -eq 0 || "$1" != *=* ]]; then
                    echo "forgejo api: -f/-F requires key=value" >&2
                    exit 1
                fi
                local kv="$1"; shift
                local key="${kv%%=*}"
                local val="${kv#*=}"
                local is_array=0
                if [[ "$key" == *"[]" ]]; then
                    is_array=1
                    key="${key%??}"
                fi

                # @file expansion (typed only)
                if [[ "$typed" -eq 1 && "$val" == @* ]]; then
                    val=$(cat "${val#@}")
                fi

                if [[ "$for_query" -eq 1 ]]; then
                    local enc_k enc_v
                    enc_k=$(printf '%s' "$key" | jq -sRr @uri)
                    enc_v=$(printf '%s' "$val" | jq -sRr @uri)
                    query_pairs+=("${enc_k}=${enc_v}")
                    continue
                fi

                local jq_arg="--arg"
                if [[ "$typed" -eq 1 ]]; then
                    case "$val" in
                        true|false) jq_arg="--argjson" ;;
                        *) [[ "$val" =~ ^-?[0-9]+$ ]] && jq_arg="--argjson" ;;
                    esac
                fi

                if [[ "$is_array" -eq 1 ]]; then
                    body_acc=$(printf '%s' "$body_acc" | \
                        jq --arg k "$key" "$jq_arg" v "$val" \
                           '. + {($k): ((.[$k] // []) + [$v])}')
                else
                    body_acc=$(printf '%s' "$body_acc" | \
                        jq --arg k "$key" "$jq_arg" v "$val" \
                           '. + {($k): $v}')
                fi
                ;;
            *)
                echo "forgejo api: unknown arg: $1" >&2
                exit 1
                ;;
        esac
    done

    if [[ "$for_query" -eq 1 && "${#query_pairs[@]}" -gt 0 ]]; then
        API_QUERY=$(IFS='&'; echo "${query_pairs[*]}")
    elif [[ -z "$API_BODY" && "$body_acc" != "{}" ]]; then
        API_BODY="$body_acc"
    fi
}

cmd_api() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo api [METHOD] <path> [-f key=val]... [-F key=val]... [--input -]" >&2
        exit 1
    fi

    local method
    case "$1" in
        GET|POST|PUT|PATCH|DELETE|HEAD)
            method="$1"; shift ;;
        *)
            method="GET" ;;
    esac

    if [[ $# -eq 0 ]]; then
        echo "forgejo api: missing path" >&2
        exit 1
    fi
    local path="$1"; shift

    local url
    case "$path" in
        http://*|https://*) url="$path" ;;
        //*)
            echo "forgejo api: path must not start with //" >&2
            exit 1 ;;
        /api/v1/*)          url="${FORGEJO_URL}${path}" ;;
        /*)                 url="${FORGEJO_URL}/api/v1${path}" ;;
        *)
            echo "forgejo api: path must start with / or http(s)://" >&2
            exit 1 ;;
    esac

    build_api_body "$method" "$@"

    if [[ -n "$API_QUERY" ]]; then
        url="${url}?${API_QUERY}"
    fi

    local tmp
    tmp=$(mktemp)
    local curl_args=(
        -s
        -X "$method"
        -H "Authorization: token $FORGEJO_TOKEN"
        -H "Accept: application/json"
        -w '%{http_code}'
        -o "$tmp"
    )
    if [[ -n "$API_BODY" ]]; then
        curl_args+=(-H "Content-Type: application/json" -d "$API_BODY")
    fi

    local status rc=0
    status=$(curl "${curl_args[@]}" "$url") || rc=$?
    if [[ "$rc" -ne 0 ]]; then
        rm -f "$tmp"
        echo "forgejo: network error (curl exit $rc)" >&2
        exit 1
    fi

    if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
        echo "forgejo api: HTTP $status" >&2
        cat "$tmp" >&2
        rm -f "$tmp"
        exit 22
    fi

    cat "$tmp"
    rm -f "$tmp"
}

# --- BRANCH COMMANDS ---

cmd_branch() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        echo "Usage: forgejo branch <action> [args]" >&2
        echo "Actions: list, view, delete, protect, unprotect" >&2
        echo "Run 'forgejo --help' for the full command reference." >&2
        exit 1
    fi
    local action="$1"; shift
    case "$action" in
        list)      branch_list "$@" ;;
        view)      branch_view "$@" ;;
        delete)    branch_delete "$@" ;;
        protect)   branch_protect "$@" ;;
        unprotect) branch_unprotect "$@" ;;
        *) echo "Unknown branch action: $action" >&2; exit 1 ;;
    esac
}

branch_list() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: forgejo branch list <owner/repo>" >&2
        exit 1
    fi
    local repo="$1"

    local result
    result=$(api_call GET "repos/$repo/branches")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        printf '%-30s %-10s %-12s %s\n' "NAME" "PROTECTED" "LAST_COMMIT" "DATE"
        echo "$result" | jq -r '
            .[] |
            [
                .name,
                (if .protected then "yes" else "no" end),
                .commit.id[:7],
                (.commit.timestamp[:10])
            ] | @tsv
        ' | while IFS=$'\t' read -r name protected sha date; do
            printf '%-30s %-10s %-12s %s\n' "$name" "$protected" "$sha" "$date"
        done
    fi
}

branch_view() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo branch view <owner/repo> <branch>" >&2
        exit 1
    fi
    local repo="$1" branch="$2"

    local branch_data
    branch_data=$(api_call GET "repos/$repo/branches/$branch")

    # Existence check on protection using the no-exit variant
    local prot_resp prot_status prot_body
    prot_resp=$(api_call_status GET "repos/$repo/branch_protections/$branch")
    prot_status=$(printf '%s' "$prot_resp" | head -1)
    prot_body=$(printf '%s' "$prot_resp" | tail -n +2)

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        local prot_json
        case "$prot_status" in
            200) prot_json="$prot_body" ;;
            404) prot_json="null" ;;
            *)   echo "branch view: protection check returned status $prot_status" >&2; exit 1 ;;
        esac
        echo "$branch_data" | jq --argjson p "$prot_json" '{branch: ., protection: $p}'
        return
    fi

    echo "$branch_data" | jq -r '
        "Branch:   \(.name)",
        "Commit:   \(.commit.id)",
        "Author:   \(.commit.author.name) (\(.commit.author.email))",
        "Date:     \(.commit.timestamp[:16] | sub("T"; " "))",
        "Message:  \(.commit.message | split("\n")[0])"
    '
    echo ""
    if [[ "$prot_status" == "200" ]]; then
        echo "$prot_body" | jq -r '
            "Protection: enabled",
            "  Push:               \(if .enable_push then "enabled" else "disabled" end)",
            "  Merge whitelist:    \(if (.merge_whitelist_usernames | length) > 0 then (.merge_whitelist_usernames | join(", ")) else "-" end)",
            "  Required approvals: \(.required_approvals)",
            "  Dismiss stale:      \(if .dismiss_stale_approvals then "yes" else "no" end)",
            "  Require signed:     \(if .require_signed_commits then "yes" else "no" end)"
        '
    elif [[ "$prot_status" == "404" ]]; then
        echo "Protection: not protected"
    else
        echo "Protection: (status $prot_status — could not fetch protection info)" >&2
        exit 1
    fi
}

branch_delete() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo branch delete <owner/repo> <branch>" >&2
        exit 1
    fi
    local repo="$1" branch="$2"

    # No confirm_delete prompt: branches are recoverable via reflog and
    # other branches in their ancestry, and the server refuses deletion
    # of protected branches. Interactive confirm would break scripted use.
    api_call DELETE "repos/$repo/branches/$branch" >/dev/null
    echo "Deleted branch $branch"
}

branch_protect() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo branch protect <owner/repo> <branch> [flags]" >&2
        exit 1
    fi
    local repo="$1" branch="$2"
    shift 2

    # Parse flags
    local no_push=0 dismiss_stale=0 require_signed=0 block_outdated=0
    local push_whitelist="" merge_whitelist="" required_approvals=""

    has_flag "--no-push" "$@" && no_push=1
    has_flag "--dismiss-stale-approvals" "$@" && dismiss_stale=1
    has_flag "--require-signed" "$@" && require_signed=1
    has_flag "--block-on-outdated" "$@" && block_outdated=1
    push_whitelist=$(get_flag "--push-whitelist" "$@" 2>/dev/null || true)
    merge_whitelist=$(get_flag "--merge-whitelist" "$@" 2>/dev/null || true)
    required_approvals=$(get_flag "--required-approvals" "$@" 2>/dev/null || true)

    if [[ "$no_push" -eq 1 && -n "$push_whitelist" ]]; then
        echo "forgejo branch protect: --no-push and --push-whitelist are mutually exclusive" >&2
        exit 1
    fi

    # Build body from flags (only set fields the user actually passed)
    local body='{}'
    if [[ "$no_push" -eq 1 ]]; then
        body=$(printf '%s' "$body" | jq '. + {enable_push: false, enable_push_whitelist: false}')
    elif [[ -n "$push_whitelist" ]]; then
        local arr
        arr=$(printf '%s' "$push_whitelist" | jq -Rc 'split(",") | map(select(length > 0))')
        body=$(printf '%s' "$body" | jq --argjson arr "$arr" \
            '. + {enable_push: true, enable_push_whitelist: true, push_whitelist_usernames: $arr}')
    fi
    if [[ -n "$merge_whitelist" ]]; then
        local arr
        arr=$(printf '%s' "$merge_whitelist" | jq -Rc 'split(",") | map(select(length > 0))')
        body=$(printf '%s' "$body" | jq --argjson arr "$arr" \
            '. + {enable_merge_whitelist: true, merge_whitelist_usernames: $arr}')
    fi
    if [[ -n "$required_approvals" ]]; then
        if ! [[ "$required_approvals" =~ ^[0-9]+$ ]]; then
            echo "forgejo branch protect: --required-approvals must be a non-negative integer" >&2
            exit 1
        fi
        body=$(printf '%s' "$body" | jq --argjson n "$required_approvals" \
            '. + {required_approvals: $n}')
    fi
    [[ "$dismiss_stale"  -eq 1 ]] && body=$(printf '%s' "$body" | jq '. + {dismiss_stale_approvals: true}')
    [[ "$require_signed" -eq 1 ]] && body=$(printf '%s' "$body" | jq '. + {require_signed_commits: true}')
    [[ "$block_outdated" -eq 1 ]] && body=$(printf '%s' "$body" | jq '. + {block_on_outdated_branch: true}')

    # Existence check (no-exit)
    local check status
    check=$(api_call_status GET "repos/$repo/branch_protections/$branch")
    status=$(printf '%s' "$check" | head -1)

    local result
    if [[ "$status" == "200" ]]; then
        result=$(api_call PATCH "repos/$repo/branch_protections/$branch" "$body")
    elif [[ "$status" == "404" ]]; then
        # Safe default if no flags given: lock branch, no approvals
        if [[ "$body" == "{}" ]]; then
            body=$(jq -n '{enable_push: false, required_approvals: 0}')
        fi
        body=$(printf '%s' "$body" | jq --arg b "$branch" '. + {branch_name: $b}')
        result=$(api_call POST "repos/$repo/branch_protections" "$body")
    else
        echo "forgejo branch protect: unexpected status $status checking existing protection" >&2
        printf '%s\n' "$check" | tail -n +2 >&2
        exit 1
    fi

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        printf '%s' "$result" | jq .
    else
        local push_state mw approvals
        push_state=$(printf '%s' "$result" | jq -r 'if .enable_push then "enabled" else "disabled" end')
        mw=$(printf '%s' "$result" | jq -r 'if (.merge_whitelist_usernames | length) > 0 then (.merge_whitelist_usernames | join(",")) else "-" end')
        approvals=$(printf '%s' "$result" | jq -r '.required_approvals')
        echo "Protected $branch on $repo (push: $push_state, merge whitelist: $mw, approvals: $approvals)"
    fi
}

branch_unprotect() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo branch unprotect <owner/repo> <branch>" >&2
        exit 1
    fi
    local repo="$1" branch="$2"

    local check status
    check=$(api_call_status DELETE "repos/$repo/branch_protections/$branch")
    status=$(printf '%s' "$check" | head -1)

    case "$status" in
        204|200)
            echo "Removed protection on $branch" ;;
        404)
            echo "Branch $branch was not protected"
            # exit 0 — idempotent
            ;;
        *)
            echo "forgejo branch unprotect: unexpected status $status" >&2
            printf '%s\n' "$check" | tail -n +2 >&2
            exit 1 ;;
    esac
}

cmd_admin() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo admin <cron|config|queue|stats|notice> [args]" >&2
        exit 1
    fi

    local action="$1"
    shift

    case "$action" in
        cron)   cmd_admin_cron   "$@" ;;
        config) cmd_admin_config "$@" ;;
        queue)  cmd_admin_queue  "$@" ;;
        stats)  cmd_admin_stats  "$@" ;;
        notice) cmd_admin_notice "$@" ;;
        *)      echo "Unknown admin command: $action" >&2; exit 1 ;;
    esac
}

# Stub for admin verbs that have no Forgejo API endpoint. Prints a
# stderr message pointing at the web UI and exits 2. Used by queue/stats/
# notice subnouns; see docs/superpowers/specs/2026-05-23-admin.md.
admin_unsupported() {
    local verb="$1"
    local web_path="$2"
    echo "forgejo: admin $verb is not exposed by the Forgejo API." >&2
    echo "Use the web UI: ${FORGEJO_URL}${web_path}" >&2
    exit 2
}

cmd_admin_stats() {
    admin_unsupported "stats" "/-/admin"
}

cmd_admin_queue() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo admin queue <list|view|pause|resume> [args]" >&2
        exit 1
    fi
    case "$1" in
        list|view|pause|resume)
            admin_unsupported "queue $1" "/-/admin/monitor/queue" ;;
        *)
            echo "Unknown admin queue command: $1" >&2; exit 1 ;;
    esac
}

cmd_admin_notice() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo admin notice <list|delete> [args]" >&2
        exit 1
    fi
    case "$1" in
        list|delete)
            admin_unsupported "notice $1" "/-/admin/notices" ;;
        *)
            echo "Unknown admin notice command: $1" >&2; exit 1 ;;
    esac
}

cmd_admin_cron() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo admin cron <list|run> [args]" >&2
        exit 1
    fi
    local action="$1"; shift
    case "$action" in
        list) admin_cron_list "$@" ;;
        run)  admin_cron_run  "$@" ;;
        *)    echo "Unknown admin cron command: $action" >&2; exit 1 ;;
    esac
}

admin_cron_list() {
    local result
    result=$(api_call GET "admin/cron?limit=50")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
        return
    fi

    echo "$result" | jq -r '
        (["NAME","SCHEDULE","NEXT","PREV","EXEC_TIMES"] | @tsv),
        (.[] | [
            (.name // "-"),
            (.schedule // "-"),
            ((.next // "-") | if . != "-" then .[:19] + "Z" else . end),
            ((.prev // "-") | if . != "-" then .[:19] + "Z" else . end),
            ((.exec_times // 0) | tostring)
        ] | @tsv)
    ' | column -t -s $'\t'
}

admin_cron_run() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: forgejo admin cron run <name>" >&2
        exit 1
    fi
    local name="$1"
    api_call POST "admin/cron/$name" > /dev/null
    echo "Triggered cron task: $name"
}

cmd_admin_config() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo admin config <view> [args]" >&2
        exit 1
    fi
    local action="$1"; shift
    case "$action" in
        view) admin_config_view "$@" ;;
        *)    echo "Unknown admin config command: $action" >&2; exit 1 ;;
    esac
}

admin_config_view() {
    local api_s att_s repo_s ui_s merged
    api_s=$(api_call  GET "settings/api")
    att_s=$(api_call  GET "settings/attachment")
    repo_s=$(api_call GET "settings/repository")
    ui_s=$(api_call   GET "settings/ui")

    merged=$(jq -n \
        --argjson api  "$api_s" \
        --argjson att  "$att_s" \
        --argjson repo "$repo_s" \
        --argjson ui   "$ui_s" \
        '{api:$api, attachment:$att, repository:$repo, ui:$ui}')

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$merged" | jq .
        return
    fi

    local section
    for section in api attachment repository ui; do
        echo "[$section]"
        echo "$merged" | jq -r --arg s "$section" '
            .[$s] | to_entries | sort_by(.key)[] |
            "\(.key): \(if (.value|type) == "array"
                        then (.value|@json)
                        else (.value|tostring)
                        end)"
        '
        echo
    done
}

# Interactive first-run setup. Runs BEFORE load_config (see MAIN), because the
# config file may not exist yet. Mints an API token over HTTP Basic auth and
# writes a 600-mode config. Forgejo requires Basic auth (not bearer) to mint
# tokens, so this cannot reuse api_call/api_call_basic (those read a
# not-yet-loaded config).
cmd_auth_login() {
    local url user password token_name host token login reply keep
    local body tmp status rc=0
    local vtmp vstatus vrc=0
    local store_password=0

    if [[ -f "$CONFIG_FILE" ]]; then
        local existing_url=""
        existing_url=$(grep -E '^FORGEJO_URL=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2- || true)
        echo "A config already exists at $CONFIG_FILE" >&2
        [[ -n "$existing_url" ]] && echo "  Current URL: $existing_url" >&2
        read -rp "Overwrite it? (y/N) " reply
        if [[ "$reply" != "y" && "$reply" != "Y" ]]; then
            echo "Aborted." >&2
            exit 1
        fi
    fi

    read -rp "Forgejo URL (e.g. https://forgejo.example.com): " url
    url="${url%/}"
    if [[ "$url" != http://* && "$url" != https://* ]]; then
        echo "URL must start with http:// or https://" >&2
        exit 1
    fi

    read -rp "Username: " user
    if [[ -z "$user" ]]; then
        echo "Username is required." >&2
        exit 1
    fi

    read -rsp "Password: " password
    echo
    if [[ -z "$password" ]]; then
        echo "Password is required." >&2
        exit 1
    fi

    host=$(hostname -s 2>/dev/null || echo host)
    token_name="forgejo-cli-${host}-$(date +%Y%m%d%H%M%S)"

    body=$(jq -n --arg n "$token_name" '{name: $n, scopes: ["all"]}')
    tmp=$(mktemp)
    status=$(curl -s -X POST \
        -u "${user}:${password}" \
        -H "Content-Type: application/json" \
        -H "Accept: application/json" \
        -d "$body" \
        -w '%{http_code}' \
        -o "$tmp" \
        "${url}/api/v1/users/${user}/tokens") || rc=$?
    if [[ "$rc" -ne 0 ]]; then
        rm -f "$tmp"
        echo "forgejo: network error (curl exit $rc)" >&2
        exit 1
    fi

    if [[ "$status" == "401" ]]; then
        rm -f "$tmp"
        echo "Authentication failed." >&2
        echo "If this account has 2FA enabled, this flow can't mint a token -- create" >&2
        echo "one in the web UI (Settings -> Applications) and set FORGEJO_TOKEN" >&2
        echo "manually in $CONFIG_FILE. Otherwise, check your username and password." >&2
        exit 1
    fi

    if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
        echo "API error ($status):" >&2
        jq -r '.message // .error // .' "$tmp" >&2 2>/dev/null || cat "$tmp" >&2
        rm -f "$tmp"
        exit 1
    fi

    token=$(jq -r '.sha1 // empty' "$tmp")
    rm -f "$tmp"
    if [[ -z "$token" ]]; then
        echo "forgejo: token endpoint returned no sha1 value." >&2
        exit 1
    fi

    vtmp=$(mktemp)
    vstatus=$(curl -s -X GET \
        -H "Authorization: token $token" \
        -H "Accept: application/json" \
        -w '%{http_code}' \
        -o "$vtmp" \
        "${url}/api/v1/user") || vrc=$?
    if [[ "$vrc" -ne 0 ]]; then
        rm -f "$vtmp"
        echo "forgejo: network error verifying token (curl exit $vrc)" >&2
        exit 1
    fi
    if [[ "$vstatus" -lt 200 || "$vstatus" -ge 300 ]]; then
        echo "Token verification failed (status $vstatus)." >&2
        rm -f "$vtmp"
        exit 1
    fi
    login=$(jq -r '.login // empty' "$vtmp")
    rm -f "$vtmp"

    read -rp "Store password for token-management commands? (y/N) " keep
    if [[ "$keep" == "y" || "$keep" == "Y" ]]; then
        store_password=1
    fi

    mkdir -p "$(dirname "$CONFIG_FILE")"
    install -m 600 /dev/null "$CONFIG_FILE"
    {
        printf 'FORGEJO_URL=%q\n' "$url"
        printf 'FORGEJO_TOKEN=%q\n' "$token"
        if [[ "$store_password" -eq 1 ]]; then
            printf 'FORGEJO_PASSWORD=%q\n' "$password"
        fi
    } > "$CONFIG_FILE"

    echo "Logged in as ${login:-$user} at $url."
}

cmd_auth() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo auth <login|status>" >&2
        exit 1
    fi
    local action="$1"; shift
    case "$action" in
        status) cmd_auth_status "$@" ;;
        *)      echo "Unknown auth command: $action" >&2; exit 1 ;;
    esac
}

cmd_auth_status() {
    local result
    result=$(api_call GET "user")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
        return
    fi

    local login email is_admin
    login=$(echo "$result"    | jq -r '.login')
    email=$(echo "$result"    | jq -r '.email // "-"')
    is_admin=$(echo "$result" | jq -r '.is_admin')

    local login_line="$login"
    if [[ "$is_admin" == "true" ]]; then
        login_line="$login (admin)"
    fi

    printf 'URL:    %s\n' "$FORGEJO_URL"
    printf 'Login:  %s\n' "$login_line"
    printf 'Email:  %s\n' "$email"
    printf 'Scopes: %s\n' "not exposed by Forgejo API"
}

cmd_notification() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo notification <list|read> [args]" >&2
        exit 1
    fi
    local action="$1"; shift
    case "$action" in
        list) cmd_notification_list "$@" ;;
        read) cmd_notification_read "$@" ;;
        *)    echo "Unknown notification command: $action" >&2; exit 1 ;;
    esac
}

cmd_notification_list() {
    local all_param status limit
    status=$(get_flag "--status" "$@" 2>/dev/null) || status=""
    limit=$(get_flag  "--limit"  "$@" 2>/dev/null) || limit=""
    all_param=""
    if has_flag "--all" "$@"; then
        all_param="all=true"
    fi

    if [[ -n "$limit" ]] && ! [[ "$limit" =~ ^[0-9]+$ ]]; then
        echo "--limit must be a non-negative integer" >&2
        exit 1
    fi

    local qs="$all_param"
    if [[ -n "$status" ]]; then
        local s
        IFS=',' read -ra _statuses <<< "$status"
        for s in "${_statuses[@]}"; do
            [[ -n "$qs" ]] && qs="${qs}&"
            qs="${qs}status-types=${s}"
        done
    fi
    if [[ -n "$limit" ]]; then
        [[ -n "$qs" ]] && qs="${qs}&"
        qs="${qs}limit=${limit}"
    fi

    local endpoint="notifications"
    [[ -n "$qs" ]] && endpoint="notifications?${qs}"

    local result
    result=$(api_call GET "$endpoint")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
        return
    fi

    if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
        echo "No notifications."
        return
    fi

    echo "$result" | jq -r '
        (["ID","REPO","TYPE","TITLE","STATE","UPDATED"] | @tsv),
        (.[] | [
            (.id|tostring),
            (.repository.full_name // "-"),
            (.subject.type // "-"),
            ((.subject.title // "-")[:60]),
            (.subject.state // "-"),
            ((.updated_at // "-") | if . != "-" then .[:19] + "Z" else . end)
        ] | @tsv)
    ' | column -t -s $'\t'
}

cmd_notification_read() {
    local has_id=0
    local id=""
    if [[ $# -gt 0 && "$1" != --* ]]; then
        id="$1"
        has_id=1
        shift
    fi
    local all=0
    if has_flag "--all" "$@"; then
        all=1
    fi

    if [[ $has_id -eq 1 && $all -eq 1 ]]; then
        echo "notification read: pass either <id> or --all, not both" >&2
        exit 2
    fi
    if [[ $has_id -eq 0 && $all -eq 0 ]]; then
        echo "Usage: forgejo notification read <id> | --all" >&2
        exit 2
    fi

    if [[ $all -eq 1 ]]; then
        api_call PUT "notifications?status-types=unread" > /dev/null
        echo "Marked all unread notifications as read"
        return
    fi

    api_call PATCH "notifications/threads/${id}?to-status=read" > /dev/null
    echo "Marked thread ${id} as read"
}

cmd_search() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo search <repos|users|issues> [args]" >&2
        exit 1
    fi
    local action="$1"; shift
    case "$action" in
        repos)  cmd_search_repos  "$@" ;;
        users)  cmd_search_users  "$@" ;;
        issues) cmd_search_issues "$@" ;;
        *)      echo "Unknown search command: $action" >&2; exit 1 ;;
    esac
}

cmd_search_repos() {
    local query owner limit
    query=$(get_flag "--query" "$@" 2>/dev/null) || query=""
    owner=$(get_flag "--owner" "$@" 2>/dev/null) || owner=""
    limit=$(get_flag "--limit" "$@" 2>/dev/null) || limit=""

    if [[ -z "$query" ]]; then
        echo "Usage: forgejo search repos --query=X [--owner=X] [--limit=N]" >&2
        exit 1
    fi
    if [[ -n "$limit" ]] && ! [[ "$limit" =~ ^[0-9]+$ ]]; then
        echo "--limit must be a non-negative integer" >&2
        exit 1
    fi

    local query_enc
    query_enc=$(printf '%s' "$query" | jq -sRr @uri)
    local qs="q=${query_enc}"

    if [[ -n "$owner" ]]; then
        local uid
        uid=$(api_call GET "users/${owner}" 2>/dev/null | jq -r '.id // empty') || true
        if [[ -z "$uid" ]]; then
            echo "forgejo: unknown owner '${owner}'" >&2
            exit 1
        fi
        qs="${qs}&uid=${uid}"
    fi
    if [[ -n "$limit" ]]; then
        qs="${qs}&limit=${limit}"
    fi

    local result
    result=$(api_call GET "repos/search?${qs}")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
        return
    fi

    if echo "$result" | jq -e '.data | length == 0' > /dev/null 2>&1; then
        echo "No repos found."
        return
    fi

    echo "$result" | jq -r '
        (["FULL_NAME","PRIVATE","ARCHIVED","STARS","DESCRIPTION"] | @tsv),
        (.data[] | [
            .full_name,
            (if .private then "yes" else "no" end),
            (if .archived then "yes" else "no" end),
            (.stars_count|tostring),
            ((.description // "")[:50])
        ] | @tsv)
    ' | column -t -s $'\t'
}

cmd_search_users() {
    local query limit
    query=$(get_flag "--query" "$@" 2>/dev/null) || query=""
    limit=$(get_flag "--limit" "$@" 2>/dev/null) || limit=""

    if [[ -z "$query" ]]; then
        echo "Usage: forgejo search users --query=X [--limit=N]" >&2
        exit 1
    fi
    if [[ -n "$limit" ]] && ! [[ "$limit" =~ ^[0-9]+$ ]]; then
        echo "--limit must be a non-negative integer" >&2
        exit 1
    fi

    local query_enc
    query_enc=$(printf '%s' "$query" | jq -sRr @uri)
    local qs="q=${query_enc}"
    if [[ -n "$limit" ]]; then
        qs="${qs}&limit=${limit}"
    fi

    local result
    result=$(api_call GET "users/search?${qs}")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
        return
    fi

    if echo "$result" | jq -e '.data | length == 0' > /dev/null 2>&1; then
        echo "No users found."
        return
    fi

    echo "$result" | jq -r '
        (["LOGIN","FULL_NAME","EMAIL","ACTIVE"] | @tsv),
        (.data[] | [
            .login,
            (if (.full_name // "") == "" then "-" else .full_name end),
            (if (.email // "") == "" then "-" else .email end),
            (if .active then "yes" else "no" end)
        ] | @tsv)
    ' | column -t -s $'\t'
}

cmd_search_issues() {
    local query type state owner limit
    query=$(get_flag "--query" "$@" 2>/dev/null) || query=""
    type=$(get_flag  "--type"  "$@" 2>/dev/null) || type=""
    state=$(get_flag "--state" "$@" 2>/dev/null) || state=""
    owner=$(get_flag "--owner" "$@" 2>/dev/null) || owner=""
    limit=$(get_flag "--limit" "$@" 2>/dev/null) || limit=""

    if [[ -z "$query" ]]; then
        echo "Usage: forgejo search issues --query=X [--type=issue|pr] [--state=open|closed|all] [--owner=X] [--limit=N]" >&2
        exit 1
    fi
    if [[ -n "$limit" ]] && ! [[ "$limit" =~ ^[0-9]+$ ]]; then
        echo "--limit must be a non-negative integer" >&2
        exit 1
    fi

    local type_param=""
    case "$type" in
        "")     type_param="" ;;
        issue)  type_param="type=issues" ;;
        pr)     type_param="type=pulls"  ;;
        *)      echo "--type must be 'issue' or 'pr' (got: $type)" >&2; exit 1 ;;
    esac

    local query_enc
    query_enc=$(printf '%s' "$query" | jq -sRr @uri)
    local qs="q=${query_enc}"

    if [[ -n "$type_param" ]]; then
        qs="${qs}&${type_param}"
    fi
    if [[ -n "$state" ]]; then
        qs="${qs}&state=${state}"
    fi
    if [[ -n "$owner" ]]; then
        local owner_enc
        owner_enc=$(printf '%s' "$owner" | jq -sRr @uri)
        qs="${qs}&owner=${owner_enc}"
    fi
    if [[ -n "$limit" ]]; then
        qs="${qs}&limit=${limit}"
    fi

    local result
    result=$(api_call GET "repos/issues/search?${qs}")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
        return
    fi

    if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
        echo "No issues found."
        return
    fi

    echo "$result" | jq -r '
        (["REPO","#","TYPE","STATE","TITLE"] | @tsv),
        (.[] | [
            (.repository.full_name // "-"),
            (.number|tostring),
            (if .pull_request then "pr" else "issue" end),
            .state,
            (.title // "")[:50]
        ] | @tsv)
    ' | column -t -s $'\t'
}

# --- MAIN ---

check_deps
# Parse global --json flag
args=()
for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then
        JSON_OUTPUT=1
    else
        args+=("$arg")
    fi
done
set -- "${args[@]+"${args[@]}"}"

if [[ $# -eq 0 ]]; then
    show_usage
    exit 0
fi

# --help / -h ANYWHERE means "show help, never run a command". This MUST run
# before load_config and before any dispatch so that a mutating verb can never
# treat --help as a positional argument. Without this, `forgejo repo create
# --help` would create a repo literally named "--help", and `forgejo repo
# delete --help` would try to delete one. route_help shows the most specific
# help available for the resource/subcommand named in the args.
for arg in "$@"; do
    if [[ "$arg" == "--help" || "$arg" == "-h" ]]; then
        route_help "$@"
        exit 0
    fi
done

if [[ "${1:-}" == "auth" && "${2:-}" == "login" ]]; then
    shift 2
    cmd_auth_login "$@"
    exit $?
fi

load_config

case "$1" in
    api)     shift; cmd_api "$@" ;;
    branch)  shift; cmd_branch "$@" ;;
    repo)    shift; cmd_repo "$@" ;;
    issue)   shift; cmd_issue "$@" ;;
    actions) shift; cmd_actions "$@" ;;
    pr)      shift; cmd_pr "$@" ;;
    release) shift; cmd_release "$@" ;;
    wiki)    shift; cmd_wiki "$@" ;;
    user)    shift; cmd_user "$@" ;;
    org)     shift; cmd_org "$@" ;;
    admin)   shift; cmd_admin "$@" ;;
    auth)         shift; cmd_auth "$@" ;;
    notification) shift; cmd_notification "$@" ;;
    search)       shift; cmd_search "$@" ;;
    *)       echo "Unknown resource: $1" >&2; show_usage; exit 1 ;;
esac
