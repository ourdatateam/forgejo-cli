issue_search() {
    local owner state labels query limit
    owner=$(get_flag "--owner" "$@" 2>/dev/null) || owner=""
    state=$(get_flag "--state" "$@" 2>/dev/null) || state="open"
    labels=$(get_flag "--labels" "$@" 2>/dev/null) || labels=""
    query=$(get_flag "--query" "$@" 2>/dev/null) || query=""
    limit=$(get_flag "--limit" "$@" 2>/dev/null) || limit="50"

    if ! [[ "$limit" =~ ^[0-9]+$ ]]; then
        echo "--limit must be a non-negative integer" >&2
        exit 1
    fi

    local qs="type=issues&state=${state}&limit=${limit}"
    if [[ -n "$owner" ]]; then
        local owner_enc
        owner_enc=$(printf '%s' "$owner" | jq -sRr @uri)
        qs="${qs}&owner=${owner_enc}"
    fi
    if [[ -n "$labels" ]]; then
        local labels_enc
        labels_enc=$(printf '%s' "$labels" | jq -sRr @uri)
        qs="${qs}&labels=${labels_enc}"
    fi
    if [[ -n "$query" ]]; then
        local query_enc
        query_enc=$(printf '%s' "$query" | jq -sRr @uri)
        qs="${qs}&q=${query_enc}"
    fi

    local result
    result=$(api_call GET "repos/issues/search?$qs")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
            echo "No issues found."
        else
            echo "$result" | jq -r '
                ["REPO","#","TITLE","STATE","AUTHOR","UPDATED"],
                (.[] | [
                    (.repository.full_name // "-"),
                    (.number|tostring),
                    .title[:50],
                    .state,
