# --- ACTIONS COMMANDS ---

cmd_actions() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo actions <list|view|watch|logs|runner|workflow|secret|variable> [args]" >&2
        exit 1
    fi

    local action="$1"
    shift

    case "$action" in
        list)     actions_list "$@" ;;
        view)     actions_view "$@" ;;
        watch)    actions_watch "$@" ;;
        logs)     actions_logs "$@" ;;
        runner)   cmd_actions_runner "$@" ;;
        workflow) cmd_actions_workflow "$@" ;;
        secret)   cmd_actions_secret "$@" ;;
        variable) cmd_actions_variable "$@" ;;
        *)        echo "Unknown actions command: $action" >&2; exit 1 ;;
    esac
}

actions_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo actions list <owner/repo>" >&2
        exit 1
    fi

    local repo="$1"
    local result
    result=$(api_call GET "repos/$repo/actions/runs?limit=20")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            .workflow_runs // [] |
            (["ID","STATUS","EVENT","BRANCH","COMMIT","STARTED","TITLE"] | @tsv),
            (.[] | [
                (.id|tostring),
                (.status // "-"),
                (.event // "-"),
                (.prettyref // "-"),
                (.commit_sha // "-")[:12],
                ((.started // .created // "-") | if . != "-" then .[:19] else . end),
                (.title // "-")[:50]
            ] | @tsv)
        ' | column -t -s $'\t'
    fi
}

actions_view() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo actions view <owner/repo> <run_id>" >&2
        exit 1
    fi

    local repo="$1"
    local run_id="$2"

    local result
    result=$(api_call GET "repos/$repo/actions/runs/$run_id")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            "Run #\(.id)",
            "Title:      \(.title // "-")",
            "Status:     \(.status // "-")",
            "Event:      \(.event // "-")",
            "Branch:     \(.prettyref // "-")",
            "Commit:     \(.commit_sha // "-" | .[:12])",
            "Started:    \(.started // .created // "-")",
            "Stopped:    \(.stopped // "-")",
            "Duration:   \(if .duration then "\(.duration / 1000000000 | floor)s" else "-" end)",
            "Trigger:    \(.trigger_user.login // "-")"
        '

        # Get jobs (tasks) for this run via index_in_repo
        local run_index
        run_index=$(echo "$result" | jq -r '.index_in_repo')

        echo ""
        echo "--- Jobs ---"
        local tasks
        tasks=$(api_call GET "repos/$repo/actions/tasks?limit=200")
        echo "$tasks" | jq -r --argjson idx "$run_index" '
            .workflow_runs // [] | map(select(.run_number == $idx)) |
            if length == 0 then "No jobs found."
            else .[] |
                "  [\(.status)] \(.name) (task_id=\(.id))"
            end
        '
    fi
}

actions_watch() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo actions watch <owner/repo> <run_id>" >&2
        exit 1
    fi

    local repo="$1"
    local run_id="$2"

    echo "Watching run #$run_id..."
    while true; do
        local result
        result=$(api_call GET "repos/$repo/actions/runs/$run_id")
        local status
        status=$(echo "$result" | jq -r '.status')
        local title
        title=$(echo "$result" | jq -r '.title // "-"')

        printf "\r%-80s" "[$status] $title"

        if [[ "$status" == "success" || "$status" == "failure" || "$status" == "cancelled" ]]; then
            echo ""
            if [[ "$status" == "success" ]]; then
                echo "Run completed successfully."
            else
                echo "Run finished: $status"
                exit 1
            fi
            break
        fi
        sleep 5
    done
}

actions_logs() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo actions logs <owner/repo> <run_id>" >&2
        exit 1
    fi

    local repo="$1"
    local run_id="$2"

    local run run_index tasks task_data count
    run=$(api_call GET "repos/$repo/actions/runs/$run_id")
    run_index=$(echo "$run" | jq -r '.index_in_repo')
    tasks=$(api_call GET "repos/$repo/actions/tasks?limit=200")
    task_data=$(echo "$tasks" | jq -c --argjson idx "$run_index" '
        .workflow_runs // [] | map(select(.run_number == $idx))
    ')
    count=$(echo "$task_data" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
        echo "No jobs found for run #$run_id" >&2
        exit 1
    fi

    # When FORGEJO_LOG_PATH is set in config (i.e. when running on the Forgejo
    # host), read zstd-compressed task logs directly from disk. Layout is
    # <FORGEJO_LOG_PATH>/<owner>/<repo>/<last-2-hex-of-task_id>/<task_id>.log.zst
    if [[ -n "$FORGEJO_LOG_PATH" ]]; then
        command -v zstd >/dev/null || {
            echo "FORGEJO_LOG_PATH is set but zstd is not installed" >&2
            exit 1
        }
        local i=0 task_id task_name task_status shard log_path
        while [[ $i -lt $count ]]; do
            task_id=$(echo "$task_data" | jq -r ".[$i].id")
            task_name=$(echo "$task_data" | jq -r ".[$i].name")
            task_status=$(echo "$task_data" | jq -r ".[$i].status")
            shard=$(printf '%02x' "$((task_id & 0xff))")
            log_path="$FORGEJO_LOG_PATH/$repo/$shard/$task_id.log.zst"
            echo "=== Job: $task_name (task_id=$task_id, status=$task_status) ==="
            if [[ -f "$log_path" ]]; then
                zstd -dc "$log_path"
            else
                echo "(log not on disk: $log_path)"
            fi
            echo ""
            i=$((i+1))
        done
        return 0
    fi

    echo "$task_data" | jq -r '.[] | "  [\(.status)] \(.name) (task_id=\(.id))"'
    echo ""
    echo "Note: Forgejo's API does not expose job logs (probed on Gitea 1.22 / Forgejo 15.0.2)."
    echo "  - View in browser: ${FORGEJO_URL}/$repo/actions/runs/$run_index"
    echo "  - On the Forgejo host, set FORGEJO_LOG_PATH in ~/.config/forgejo-cli/config"
    echo "    (e.g. FORGEJO_LOG_PATH=/srv/forgejo/data/gitea/actions_log) to read from disk."
}

# Resolves the API path prefix for a runner/secret/variable subcommand from
# scope tokens in the args. Returns one of:
#   admin/actions                       (--admin flag present)
#   repos/<owner>/<repo>/actions        (first positional contains '/')
#   orgs/<owner>/actions                (first positional has no '/')
actions_scope_path() {
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "--admin" ]]; then
            printf '%s\n' "admin/actions"
            return 0
        fi
    done
    for arg in "$@"; do
        [[ "$arg" == --* ]] && continue
        if [[ "$arg" == */* ]]; then
            printf '%s\n' "repos/$arg/actions"
        else
            printf '%s\n' "orgs/$arg/actions"
        fi
        return 0
    done
    echo "Missing scope: expected <owner/repo>, <org>, or --admin" >&2
    return 1
}

# Returns the positional args (one per line) after dropping the scope token:
#   --admin                         -> drop only --admin
#   first positional (no --admin)   -> drop that positional
# Other flags (--json, --yes, etc.) are also dropped so callers can pick
# subsequent positionals (e.g. runner_id, secret name) cleanly.
actions_scope_skip_args() {
    local has_admin=0 arg
    for arg in "$@"; do
        [[ "$arg" == "--admin" ]] && { has_admin=1; break; }
    done

    local skipped=0 result=()
    for arg in "$@"; do
        [[ "$arg" == "--admin" ]] && continue
        [[ "$arg" == --* ]] && continue
        if [[ $has_admin -eq 0 && $skipped -eq 0 ]]; then
            skipped=1
            continue
        fi
        result+=("$arg")
    done
    if [[ ${#result[@]} -gt 0 ]]; then
        printf '%s\n' "${result[@]}"
    fi
}

cmd_actions_runner() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo actions runner <list|register|delete> [args]" >&2
        exit 1
    fi
    local sub="$1"; shift
    case "$sub" in
        list)     actions_runner_list "$@" ;;
        register) actions_runner_register "$@" ;;
        delete)   actions_runner_delete "$@" ;;
        *) echo "Unknown actions runner command: $sub" >&2; exit 1 ;;
    esac
}

actions_runner_list() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local result
    result=$(api_call GET "$scope/runners")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            (if type == "array" then . else (.runners // []) end) as $rs |
            (["ID","NAME","STATUS","LABELS","VERSION"] | @tsv),
            ($rs[] | [
                (.id|tostring),
                (.name // "-"),
                (.status // "-"),
                ((.labels // []) | join(",") | if . == "" then "-" else . end),
                (.version // "-")
            ] | @tsv)
        ' | column -t -s $'\t'
    fi
}

actions_runner_register() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local result
    result=$(api_call GET "$scope/runners/registration-token")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '.token // empty'
    fi
}

actions_runner_delete() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local rest=()
    mapfile -t rest < <(actions_scope_skip_args "$@")
    local runner_id="${rest[0]:-}"
    if [[ -z "$runner_id" ]]; then
        echo "Usage: forgejo actions runner delete <owner/repo|org|--admin> <runner_id> [--yes]" >&2
        exit 1
    fi
    confirm_delete "runner" "$runner_id" "$@"
    api_call DELETE "$scope/runners/$runner_id" >/dev/null
    echo "Deleted runner $runner_id"
}

cmd_actions_workflow() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo actions workflow <list|dispatch> [args]" >&2
        exit 1
    fi
    local sub="$1"; shift
    case "$sub" in
