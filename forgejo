cmd_issue() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_issue_help
        exit 0
    fi

    local action="$1"
    shift

    case "$action" in
        list)    issue_list "$@" ;;
        create)  issue_create "$@" ;;
        view)    issue_view "$@" ;;
        edit)    issue_edit "$@" ;;
        comment) issue_comment "$@" ;;
        label)   issue_label "$@" ;;
        close)   issue_close "$@" ;;
        reopen)  issue_reopen "$@" ;;
        assign)     issue_assign "$@" ;;
        unassign)   issue_unassign "$@" ;;
        search)     issue_search "$@" ;;
        milestone)  issue_milestone "$@" ;;
        *)       echo "Unknown issue action: $action" >&2; exit 1 ;;
    esac
}

issue_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo issue list <owner/repo> [--state=open|closed]" >&2
        exit 1
    fi

    local repo="$1"
    shift
    local state
    state=$(get_flag "--state" "$@" 2>/dev/null) || state="open"

    local result
    result=$(api_call GET "repos/$repo/issues?state=$state&type=issues&limit=50")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            ["#","TITLE","STATE","AUTHOR","UPDATED"],
            (.[] | [(.number|tostring), .title[:60], .state, .user.login, .updated_at[:10]])
            | @tsv
        ' | column -t -s $'\t'
    fi
}

issue_create() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo issue create <owner/repo> --title=X [--body=X] [--labels=X]" >&2
        exit 1
    fi

    local repo="$1"
    shift

    local title
    title=$(get_flag "--title" "$@" 2>/dev/null) || { echo "Missing --title" >&2; exit 1; }
    local body_text
    body_text=$(get_flag "--body" "$@" 2>/dev/null) || body_text=""

    local body
    body=$(jq -n \
        --arg title "$title" \
        --arg body "$body_text" \
        '{title: $title, body: $body}')

    # --labels was advertised in usage but never applied. CreateIssueOption
    # accepts a labels array of IDs, so resolve names and add them.
    local labels_str
    if labels_str=$(get_flag "--labels" "$@" 2>/dev/null); then
        local ids=()
        local label_names name id
        IFS=',' read -ra label_names <<< "$labels_str"
        for name in "${label_names[@]}"; do
            name=$(echo "$name" | xargs)  # trim whitespace
            [[ -z "$name" ]] && continue
            id=$(resolve_label_id "$repo" "$name") || exit 1
            ids+=("$id")
        done
        local labels_json
        labels_json=$(printf '%s\n' "${ids[@]}" | jq -s '.')
        body=$(echo "$body" | jq --argjson labels "$labels_json" '. + {labels: $labels}')
    fi

    local result
    result=$(api_call POST "repos/$repo/issues" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created issue #\(.number): \(.title)\nURL: \(.html_url)"'
    fi
}

issue_view() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue view <owner/repo> <number>" >&2
        exit 1
    fi

    local repo="$1"
    local number="$2"

    local result
    result=$(api_call GET "repos/$repo/issues/$number")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            "#\(.number): \(.title)",
            "State:   \(.state)",
            "Author:  \(.user.login)",
            "Created: \(.created_at[:10])",
            "Labels:  \(if (.labels | length) > 0 then ([.labels[].name] | join(", ")) else "-" end)",
            "",
            (.body // "(no body)")
        '

        echo ""
        echo "--- Comments ---"

        local comments
        comments=$(api_call GET "repos/$repo/issues/$number/comments")
        echo "$comments" | jq -r '
            if length == 0 then "No comments."
            else .[] | "[comment #\(.id)] \(.user.login) (\(.created_at[:10])):\n\(.body)\n"
            end
        '
    fi
}

issue_edit() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue edit <owner/repo> <number> [--title=X] [--state=X] [--body=X] [--labels=X,Y]" >&2
        exit 1
    fi

    local repo="$1"
    local number="$2"
    shift 2
    local body="{}"

    local val
    if val=$(get_flag "--title" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {title: $v}')
    fi
    if val=$(get_flag "--state" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {state: $v}')
    fi
    if val=$(get_flag "--body" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {body: $v}')
    fi

    # --labels replaces all labels on the issue. EditIssueOption has NO labels
    # field, so a PATCH silently drops it; labels must go through the dedicated
    # PUT /issues/{n}/labels endpoint (IssueLabelsOption), which replaces the set.
    local labels_json=""
    if val=$(get_flag "--labels" "$@" 2>/dev/null); then
        local ids=()
        local label_names name id
        IFS=',' read -ra label_names <<< "$val"
        for name in "${label_names[@]}"; do
            name=$(echo "$name" | xargs)  # trim whitespace
            [[ -z "$name" ]] && continue
            id=$(resolve_label_id "$repo" "$name") || exit 1
            ids+=("$id")
        done
        # Empty array (--labels=) clears all labels.
        if [[ ${#ids[@]} -eq 0 ]]; then
            labels_json="[]"
        else
            labels_json=$(printf '%s\n' "${ids[@]}" | jq -s '.')
        fi
    fi

    local result=""
    # Only PATCH if there are non-label fields to change.
    if [[ "$body" != "{}" ]]; then
        result=$(api_call PATCH "repos/$repo/issues/$number" "$body")
    fi
    # Apply the label replacement via its own endpoint.
    if [[ -n "$labels_json" ]]; then
        api_call PUT "repos/$repo/issues/$number/labels" \
            "$(jq -n --argjson l "$labels_json" '{labels: $l}')" > /dev/null
    fi
    # If nothing was changed at all, say so loudly rather than no-op silently.
    if [[ "$body" == "{}" && -z "$labels_json" ]]; then
        echo "No fields to update. Provide --title, --state, --body, or --labels." >&2
        exit 1
    fi
    # Fetch the issue for a consistent result message when we only touched labels.
    [[ -z "$result" ]] && result=$(api_call GET "repos/$repo/issues/$number")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "Updated issue #$(echo "$result" | jq -r '.number'): $(echo "$result" | jq -r '.title')"
    fi
}

issue_comment() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_issue_comment_help
        exit 0
    fi

    # Handle: forgejo issue comment delete <owner/repo> <comment_id>
    if [[ "$1" == "delete" ]]; then
        if [[ $# -lt 3 ]]; then
            echo "Usage: forgejo issue comment delete <owner/repo> <comment_id>" >&2
            exit 1
        fi
        local repo="$2"
        local comment_id="$3"
        api_call DELETE "repos/$repo/issues/comments/$comment_id" > /dev/null
        echo "Deleted comment #$comment_id"
        return
    fi

    local repo="$1"
    local number="$2"
    shift 2

    local body_text
    body_text=$(get_flag "--body" "$@" 2>/dev/null) || { echo "Missing --body" >&2; exit 1; }

    local body
    body=$(jq -n --arg body "$body_text" '{body: $body}')

    local result
    result=$(api_call POST "repos/$repo/issues/$number/comments" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "Comment added to issue #$number"
    fi
}
issue_label() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue label <owner/repo> <action> [args]" >&2
        echo "" >&2
        echo "Actions:" >&2
        echo "  list                          List repo labels" >&2
        echo "  create --name=X [--color=X] [--desc=X]  Create label" >&2
        echo "  add <number> --labels=X,Y     Add labels to issue" >&2
        echo "  remove <number> --label=X     Remove label from issue" >&2
        exit 1
    fi

    local repo="$1"
    local action="$2"
    shift 2

    case "$action" in
        list)   label_list "$repo" "$@" ;;
        create) label_create "$repo" "$@" ;;
        add)    label_add "$repo" "$@" ;;
        remove) label_remove "$repo" "$@" ;;
        *)      echo "Unknown label action: $action" >&2; exit 1 ;;
    esac
}

# Resolve label name to ID; checks org labels first, then repo labels
resolve_label_id() {
    local repo="$1"
    local name="$2"
    local org="${repo%%/*}"
    local id=""

    # Check org-level labels first
    local org_labels
    org_labels=$(api_call GET "orgs/$org/labels?limit=50" 2>/dev/null) || true
    if [[ -n "$org_labels" ]]; then
        id=$(echo "$org_labels" | jq -r --arg n "$name" '.[] | select(.name == $n) | .id')
    fi

    # Fall back to repo-level labels
    if [[ -z "$id" ]]; then
        local repo_labels
        repo_labels=$(api_call GET "repos/$repo/labels?limit=50")
        id=$(echo "$repo_labels" | jq -r --arg n "$name" '.[] | select(.name == $n) | .id')
    fi

    if [[ -z "$id" ]]; then
        echo "Label not found: $name (in org $org or repo $repo)" >&2
        return 1
    fi
    echo "$id"
}

# Resolve milestone identifier to numeric ID. If input is a positive integer,
# echo it back. Otherwise treat as title, GET milestones (all states), and
# find by exact title. Exits 1 if title not found.
resolve_milestone_id() {
    local repo="$1"
    local input="$2"

    if [[ "$input" =~ ^[0-9]+$ ]]; then
        echo "$input"
        return 0
    fi

    local id
    id=$(api_call GET "repos/$repo/milestones?state=all&limit=50" \
        | jq -r --arg t "$input" '.[] | select(.title == $t) | .id' \
        | head -1)

    if [[ -z "$id" ]]; then
        echo "Milestone not found: $input (in $repo)" >&2
        return 1
    fi
    echo "$id"
}

label_list() {
    local repo="$1"
    local org="${repo%%/*}"
    shift

    # Check for --scope=repo flag, default to org
    local scope
    scope=$(get_flag "--scope" "$@" 2>/dev/null) || scope="org"

    local result
    if [[ "$scope" == "repo" ]]; then
        result=$(api_call GET "repos/$repo/labels?limit=50")
    else
        result=$(api_call GET "orgs/$org/labels?limit=50")
    fi

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            ["ID","NAME","COLOR","DESCRIPTION"],
            (.[] | [(.id|tostring), .name, .color, (.description // "-")[:40]])
            | @tsv
        ' | column -t -s $'\t'
    fi
}

label_create() {
    local repo="$1"
    local org="${repo%%/*}"
    shift

    local name color desc scope
    name=$(get_flag "--name" "$@" 2>/dev/null) || { echo "Missing --name" >&2; exit 1; }
    color=$(get_flag "--color" "$@" 2>/dev/null) || color="#0075ca"
    desc=$(get_flag "--desc" "$@" 2>/dev/null) || desc=""
    scope=$(get_flag "--scope" "$@" 2>/dev/null) || scope="org"

    # Strip leading # from color if present
    color="${color#\#}"

    local body
    body=$(jq -n \
        --arg name "$name" \
        --arg color "#$color" \
        --arg desc "$desc" \
        '{name: $name, color: $color, description: $desc}')

    local endpoint
    if [[ "$scope" == "repo" ]]; then
        endpoint="repos/$repo/labels"
    else
        endpoint="orgs/$org/labels"
    fi

    local result
    result=$(api_call POST "$endpoint" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "Created label: $(echo "$result" | jq -r '.name') (id=$(echo "$result" | jq -r '.id'), scope=$scope)"
    fi
}

label_add() {
    local repo="$1"
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue label <owner/repo> add <number> --labels=X,Y" >&2
        exit 1
    fi
    local number="$2"
    shift 2

    local labels_str
    labels_str=$(get_flag "--labels" "$@" 2>/dev/null) || { echo "Missing --labels" >&2; exit 1; }

    # Resolve each label name to ID
    local ids=()
    IFS=',' read -ra label_names <<< "$labels_str"
    for name in "${label_names[@]}"; do
        name=$(echo "$name" | xargs)  # trim whitespace
        local id
        id=$(resolve_label_id "$repo" "$name") || exit 1
        ids+=("$id")
    done

    local body
    body=$(printf '%s\n' "${ids[@]}" | jq -s '{labels: .}')

    local result
    result=$(api_call POST "repos/$repo/issues/$number/labels" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "Added labels to issue #$number: $labels_str"
    fi
}

label_remove() {
    local repo="$1"
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue label <owner/repo> remove <number> --label=X" >&2
        exit 1
    fi
    local number="$2"
    shift 2

    local label_name
    label_name=$(get_flag "--label" "$@" 2>/dev/null) || { echo "Missing --label" >&2; exit 1; }

    local id
    id=$(resolve_label_id "$repo" "$label_name") || exit 1

    api_call DELETE "repos/$repo/issues/$number/labels/$id" > /dev/null
    echo "Removed label from issue #$number: $label_name"
}

# Add or remove assignees on an issue. GETs the current set, computes the
# new set (union for "add", set-difference for "remove"), PATCHes back.
# Always issues the PATCH even if the resulting set is unchanged.
#
# Args: <owner/repo> <number> <add|remove> <comma_separated_users>
update_issue_assignees() {
    local repo="$1"
    local number="$2"
    local op="$3"
    local users_csv="$4"

    if [[ -z "$users_csv" ]]; then
        echo "No users provided" >&2
        exit 1
    fi

    local users_json
    users_json=$(echo "$users_csv" | jq -Rc 'split(",") | map(gsub("^\\s+|\\s+$"; ""))')

    local current
    current=$(api_call GET "repos/$repo/issues/$number" | jq -c '[.assignees[]?.login]')

    local new_set
    if [[ "$op" == "add" ]]; then
        new_set=$(jq -nc --argjson cur "$current" --argjson add "$users_json" \
            '($cur + $add) | unique')
    else
        new_set=$(jq -nc --argjson cur "$current" --argjson rm "$users_json" \
            '$cur - $rm')
    fi

    local body
    body=$(jq -nc --argjson a "$new_set" '{assignees: $a}')

    local result
    result=$(api_call PATCH "repos/$repo/issues/$number" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        local verb final
        if [[ "$op" == "add" ]]; then verb="Assigned"; else verb="Unassigned"; fi
        final=$(echo "$result" | jq -r '[.assignees[]?.login] | join(", ") | if length == 0 then "(none)" else . end')
        echo "$verb $users_csv on issue #$number. Current assignees: $final"
    fi
}

