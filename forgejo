repo_webhook_create() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo webhook create <owner/repo> --url=X --events=a,b [--secret=X] [--content-type=json|form] [--inactive]" >&2
        exit 1
    fi
    local repo="$1"
    shift

    local url
    local events
    local secret
    local content_type
    url=$(get_flag "--url" "$@" 2>/dev/null) || { echo "Missing --url" >&2; exit 1; }
    events=$(get_flag "--events" "$@" 2>/dev/null) || { echo "Missing --events" >&2; exit 1; }
    secret=$(get_flag "--secret" "$@" 2>/dev/null) || secret=""
    content_type=$(get_flag "--content-type" "$@" 2>/dev/null) || content_type="json"

    local active="true"
    has_flag "--inactive" "$@" && active="false"

    local events_json
    events_json=$(echo "$events" | jq -Rc 'split(",") | map(gsub("^\\s+|\\s+$"; ""))')

    local config_json
    config_json=$(jq -nc \
        --arg u "$url" \
        --arg c "$content_type" \
        --arg s "$secret" \
        '{url: $u, content_type: $c} + (if $s != "" then {secret: $s} else {} end)')

    local body
    body=$(jq -nc \
        --argjson cfg "$config_json" \
        --argjson ev "$events_json" \
        --argjson act "$active" \
        '{type: "forgejo", config: $cfg, events: $ev, active: $act}')

    local result
    result=$(api_call POST "repos/$repo/hooks" "$body")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created webhook #\(.id) on \(.config.url)"'
    fi
}

repo_webhook_edit() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo repo webhook edit <owner/repo> <id> [--url=X] [--events=a,b] [--secret=X] [--content-type=X] [--active|--inactive]" >&2
        exit 1
    fi
    local repo="$1"
    local id="$2"
    shift 2

    if has_flag "--active" "$@" && has_flag "--inactive" "$@"; then
        echo "--active and --inactive are mutually exclusive" >&2; exit 1
    fi

    local body="{}"

    # Config keys (url / content_type / secret) — only included if any of them
    # was supplied. PATCH accepts a partial config object that overlays.
    local url
    local content_type
    local secret
    local have_cfg=0
    if url=$(get_flag "--url" "$@" 2>/dev/null); then have_cfg=1; fi
    if content_type=$(get_flag "--content-type" "$@" 2>/dev/null); then have_cfg=1; fi
    if secret=$(get_flag "--secret" "$@" 2>/dev/null); then have_cfg=1; fi

    if [[ "$have_cfg" -eq 1 ]]; then
        local cfg
        cfg=$(jq -nc \
            --arg u "${url:-}" \
            --arg c "${content_type:-}" \
            --arg s "${secret:-}" \
            '{} + (if $u != "" then {url: $u} else {} end)
               + (if $c != "" then {content_type: $c} else {} end)
               + (if $s != "" then {secret: $s} else {} end)')
        body=$(echo "$body" | jq --argjson cfg "$cfg" '. + {config: $cfg}')
    fi

    local events
    if events=$(get_flag "--events" "$@" 2>/dev/null); then
        local events_json
        events_json=$(echo "$events" | jq -Rc 'split(",") | map(gsub("^\\s+|\\s+$"; ""))')
        body=$(echo "$body" | jq --argjson ev "$events_json" '. + {events: $ev}')
    fi

    if has_flag "--active" "$@"; then
        body=$(echo "$body" | jq '. + {active: true}')
    elif has_flag "--inactive" "$@"; then
        body=$(echo "$body" | jq '. + {active: false}')
    fi

    if [[ "$body" == "{}" ]]; then
        echo "No webhook fields supplied to edit" >&2; exit 1
    fi

    local result
    result=$(api_call PATCH "repos/$repo/hooks/$id" "$body")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "Updated webhook #$id on $repo"
    fi
}

repo_webhook_delete() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo repo webhook delete <owner/repo> <id>" >&2
        exit 1
    fi
    api_call DELETE "repos/$1/hooks/$2" > /dev/null
    echo "Deleted webhook #$2 from $1"
}

cmd_repo_key() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo key <list|add|delete> [args]" >&2
        exit 1
    fi
    local action="$1"
    shift
    case "$action" in
        list)   repo_key_list "$@" ;;
        add)    repo_key_add "$@" ;;
        delete) repo_key_delete "$@" ;;
        *)      echo "Unknown key action: $action" >&2; exit 1 ;;
    esac
}

repo_key_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo key list <owner/repo>" >&2
        exit 1
    fi
    local result
    result=$(api_call GET "repos/$1/keys")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            ["ID","TITLE","FINGERPRINT","READONLY"],
            (.[] | [(.id|tostring), (.title // "-"), (.fingerprint // "-"), (if .read_only then "yes" else "no" end)])
            | @tsv
        ' | column -t -s $'\t'
    fi
}

repo_key_add() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo key add <owner/repo> --title=X (--key=X | --key-file=path) [--read-only]" >&2
        exit 1
    fi
    local repo="$1"
    shift

    local title
    title=$(get_flag "--title" "$@" 2>/dev/null) || { echo "Missing --title" >&2; exit 1; }

    local key
    key=$(read_key_input "$@")

    local read_only="false"
    has_flag "--read-only" "$@" && read_only="true"

    local body
    body=$(jq -n \
        --arg t "$title" \
        --arg k "$key" \
        --argjson ro "$read_only" \
        '{title: $t, key: $k, read_only: $ro}')

    local result
    result=$(api_call POST "repos/$repo/keys" "$body")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Added deploy key #\(.id): \(.title)"'
    fi
}

repo_key_delete() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo repo key delete <owner/repo> <id>" >&2
        exit 1
    fi
    api_call DELETE "repos/$1/keys/$2" > /dev/null
    echo "Deleted deploy key #$2 from $1"
}

cmd_repo_topic() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo topic <list|add|remove> [args]" >&2
        exit 1
    fi
    local action="$1"
    shift
    case "$action" in
        list)   repo_topic_list "$@" ;;
        add)    repo_topic_add "$@" ;;
        remove) repo_topic_remove "$@" ;;
        *)      echo "Unknown topic action: $action" >&2; exit 1 ;;
    esac
}

repo_topic_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo topic list <owner/repo>" >&2
        exit 1
    fi
    local result
    result=$(api_call GET "repos/$1/topics")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '.topics[]?'
    fi
}

repo_topic_add() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo topic add <owner/repo> --topics=a,b" >&2
        exit 1
    fi
    local repo="$1"
    shift

    local topics
    topics=$(get_flag "--topics" "$@" 2>/dev/null) || { echo "Missing --topics" >&2; exit 1; }

    local added=()
    local t
    while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        api_call PUT "repos/$repo/topics/$t" > /dev/null
        added+=("$t")
    done < <(echo "$topics" | jq -Rr 'split(",") | map(gsub("^\\s+|\\s+$"; "")) | .[]')
    echo "Added topics to $repo: ${added[*]}"
}

repo_topic_remove() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo repo topic remove <owner/repo> --topics=a,b" >&2
        exit 1
    fi
    local repo="$1"
    shift

    local topics
    topics=$(get_flag "--topics" "$@" 2>/dev/null) || { echo "Missing --topics" >&2; exit 1; }

    local removed=()
    local t
    while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        api_call DELETE "repos/$repo/topics/$t" > /dev/null
        removed+=("$t")
    done < <(echo "$topics" | jq -Rr 'split(",") | map(gsub("^\\s+|\\s+$"; "")) | .[]')
    echo "Removed topics from $repo: ${removed[*]}"
}

