milestone_list() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: forgejo issue milestone list <owner/repo> [--state=open|closed|all]" >&2
        exit 1
    fi
    local repo="$1"
    shift
    local state
    state=$(get_flag "--state" "$@" 2>/dev/null) || state="open"

    local result
    result=$(api_call GET "repos/$repo/milestones?state=${state}&limit=50")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
            echo "No milestones found."
        else
            echo "$result" | jq -r '
                ["ID","TITLE","STATE","DUE","OPEN","CLOSED"],
                (.[] | [
                    (.id|tostring),
                    .title[:40],
                    .state,
                    ((.due_on // "-")[:10]),
                    (.open_issues|tostring),
                    (.closed_issues|tostring)
                ])
                | @tsv
            ' | column -t -s $'\t'
        fi
    fi
}

milestone_create() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: forgejo issue milestone create <owner/repo> --title=X [--description=X] [--due=YYYY-MM-DD]" >&2
        exit 1
    fi
    local repo="$1"
    shift

    local title desc due
    title=$(get_flag "--title" "$@" 2>/dev/null) || { echo "Missing --title" >&2; exit 1; }
    desc=$(get_flag "--description" "$@" 2>/dev/null) || desc=""
    due=$(get_flag "--due" "$@" 2>/dev/null) || due=""

    local due_iso=""
    if [[ -n "$due" ]]; then
        if ! [[ "$due" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
            echo "--due must be YYYY-MM-DD" >&2
            exit 1
        fi
        due_iso="${due}T00:00:00Z"
    fi

    local body
    if [[ -n "$due_iso" ]]; then
        body=$(jq -n --arg t "$title" --arg d "$desc" --arg due "$due_iso" \
            '{title: $t, description: $d, due_on: $due}')
    else
        body=$(jq -n --arg t "$title" --arg d "$desc" \
            '{title: $t, description: $d}')
    fi

    local result
    result=$(api_call POST "repos/$repo/milestones" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created milestone #\(.id): \(.title)"'
    fi
}

milestone_edit() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue milestone edit <owner/repo> <id> [--title=X] [--description=X] [--due=YYYY-MM-DD] [--state=open|closed]" >&2
        exit 1
    fi
    local repo="$1"
    local id="$2"
    shift 2

    local body="{}"
    local val

    if val=$(get_flag "--title" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {title: $v}')
    fi
    if val=$(get_flag "--description" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {description: $v}')
    fi
    if val=$(get_flag "--state" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {state: $v}')
    fi
    if val=$(get_flag "--due" "$@" 2>/dev/null); then
        if ! [[ "$val" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
            echo "--due must be YYYY-MM-DD" >&2
            exit 1
        fi
        body=$(echo "$body" | jq --arg v "${val}T00:00:00Z" '. + {due_on: $v}')
    fi

    if [[ "$body" == "{}" ]]; then
        echo "No fields to update. Provide --title, --description, --due, or --state." >&2
        exit 1
    fi

    local result
    result=$(api_call PATCH "repos/$repo/milestones/$id" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Updated milestone #\(.id): \(.title) (state=\(.state))"'
    fi
}

milestone_delete() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue milestone delete <owner/repo> <id>" >&2
        exit 1
    fi
    local repo="$1"
    local id="$2"

    api_call DELETE "repos/$repo/milestones/$id" > /dev/null
    echo "Deleted milestone #$id"
}

milestone_set() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo issue milestone set <owner/repo> <number> --milestone=<id|title>" >&2
        echo "  Pass --milestone=0 to clear." >&2
        exit 1
    fi
    local repo="$1"
    local number="$2"
    shift 2

    local raw
    raw=$(get_flag "--milestone" "$@" 2>/dev/null) || { echo "Missing --milestone" >&2; exit 1; }

    local id
    if [[ "$raw" == "0" ]]; then
        id=0
    else
        id=$(resolve_milestone_id "$repo" "$raw") || exit 1
    fi

    local body
    body=$(jq -n --argjson m "$id" '{milestone: $m}')

    local result
    result=$(api_call PATCH "repos/$repo/issues/$number" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        local title
        title=$(echo "$result" | jq -r '.milestone.title // "(none)"')
        echo "Set milestone on issue #$number to: $title"
    fi
}

# Resolves <team-name-or-id> to numeric team id within an org.
# Numeric input passes through. Names hit /orgs/{org}/teams/search?q= and
# match on exact .name (case-sensitive). Errors on no-match or ambiguous.
resolve_team_id() {
    local org="$1" needle="$2"
    if [[ "$needle" =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$needle"
        return 0
    fi
    local result hits
    result=$(api_call GET "orgs/$org/teams/search?q=$(jq -rn --arg s "$needle" '$s|@uri')")
    hits=$(echo "$result" | jq --arg n "$needle" '[.data[]? | select(.name == $n)]')
    local count
    count=$(echo "$hits" | jq 'length')
    if [[ "$count" -eq 0 ]]; then
        echo "No team named '$needle' in org '$org'" >&2
        echo "Available:" >&2
        echo "$result" | jq -r '.data[]? | "  " + .name' >&2
        exit 1
    fi
    if [[ "$count" -gt 1 ]]; then
        echo "Ambiguous team name '$needle' in org '$org' (matched $count)" >&2
        exit 1
    fi
    echo "$hits" | jq -r '.[0].id'
}

# Resolves --key=<value>: if value starts with '@', read file; else literal.
# Strips trailing newline. Errors if file missing.
read_key_arg() {
    local val="$1"
    if [[ "${val:0:1}" == "@" ]]; then
        local path="${val:1}"
        [[ -f "$path" ]] || { echo "Key file not found: $path" >&2; exit 1; }
        # shellcheck disable=SC2005
        printf '%s' "$(cat "$path")"
    else
        printf '%s' "$val"
    fi
}

