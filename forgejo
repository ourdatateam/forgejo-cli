user_edit() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo user edit <username> [--email=X] [--admin=true|false] [--active=true|false]" >&2
        exit 1
    fi

    local username="$1"
    shift

    # Fetch current user data for required fields
    local current
    current=$(api_call GET "users/$username")
    local login_name source_id
    login_name=$(echo "$current" | jq -r '.login')
    source_id=$(echo "$current" | jq -r '.source_id // 0')

    local body
    body=$(jq -n \
        --arg login "$login_name" \
        --argjson source_id "$source_id" \
        '{login_name: $login, source_id: $source_id}')

    local val
    if val=$(get_flag "--email" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {email: $v}')
    fi
    if val=$(get_flag "--admin" "$@" 2>/dev/null); then
        # EditUserOption's field is `admin`, not `site_admin`; the wrong name
        # was silently dropped, so --admin never changed anything.
        if [[ "$val" == "true" ]]; then
            body=$(echo "$body" | jq '. + {admin: true}')
        else
            body=$(echo "$body" | jq '. + {admin: false}')
        fi
    fi
    if val=$(get_flag "--active" "$@" 2>/dev/null); then
        if [[ "$val" == "true" ]]; then
            body=$(echo "$body" | jq '. + {active: true}')
        else
            body=$(echo "$body" | jq '. + {active: false}')
        fi
    fi

    local result
    result=$(api_call PATCH "admin/users/$username" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "Updated user: $(echo "$result" | jq -r '.login')"
    fi
}

