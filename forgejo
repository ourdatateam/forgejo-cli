}

pr_checks() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr checks <owner/repo> <number>" >&2
        exit 1
    fi
    local repo="$1"
    local number="$2"

    local sha
    sha=$(api_call GET "repos/$repo/pulls/$number" | jq -r '.head.sha')

    if [[ -z "$sha" || "$sha" == "null" ]]; then
        echo "Could not resolve head SHA for PR #$number" >&2
        exit 1
    fi

    local statuses runs
    statuses=$(api_call GET "repos/$repo/commits/$sha/statuses")
    runs=$(api_call GET "repos/$repo/actions/runs?head_sha=$sha" 2>/dev/null) || runs='{"workflow_runs":[]}'

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        jq -n --argjson s "$statuses" --argjson r "$runs" \
            '{statuses: $s, actions: ($r.workflow_runs // [])}'
        return
    fi

    local merged
    merged=$(jq -n --argjson s "$statuses" --argjson r "$runs" '
        ($s | map({source:"status", name:(.context // "-"), status:.status, url:(.target_url // "-")})) +
        (($r.workflow_runs // []) | map({source:"action", name:(.name // "-"), status:(.conclusion // .status // "-"), url:(.html_url // "-")}))
    ')

    if echo "$merged" | jq -e 'length == 0' > /dev/null 2>&1; then
        echo "No checks found for PR #$number (head $sha)."
    else
        echo "$merged" | jq -r '
            ["SOURCE","NAME","STATUS","URL"],
            (.[] | [.source, .name, .status, .url])
            | @tsv
        ' | column -t -s $'\t'
    fi
}

pr_review() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        cat << 'REVIEW_HELP'
PR review commands:
  forgejo pr review <owner/repo> <number> --approve [--body=TEXT]
      Approve a PR. --body is optional for approvals.

  forgejo pr review <owner/repo> <number> --request-changes --body=TEXT
      Request changes on a PR. --body is REQUIRED.

  forgejo pr review <owner/repo> <number> --comment --body=TEXT
      Leave a general review comment. --body is REQUIRED.

  forgejo pr review list <owner/repo> <number>
      List all reviews on a PR (ID, user, state, date).

  forgejo pr review dismiss <owner/repo> <number> <review_id> --message=TEXT
      Dismiss a previous review by its ID. --message is REQUIRED.

Exactly one of --approve, --request-changes, --comment is required.
The flags are mutually exclusive.

EXAMPLES:
  forgejo pr review myorg/myrepo 17 --approve
  forgejo pr review myorg/myrepo 17 --request-changes --body="Please add tests."
  forgejo pr review myorg/myrepo 17 --comment --body="One nit: rename the variable."
  forgejo pr review list myorg/myrepo 17
  forgejo pr review dismiss myorg/myrepo 17 42 --message="Stale review"

REVIEW_HELP
        exit 0
    fi

    case "$1" in
        list)    shift; pr_review_list "$@" ;;
        dismiss) shift; pr_review_dismiss "$@" ;;
        *)       pr_review_create "$@" ;;
    esac
}

pr_review_create() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr review <owner/repo> <number> --approve|--request-changes|--comment [--body=X]" >&2
        exit 1
    fi
    local repo="$1"
    local number="$2"
    shift 2

    local count=0
    local event=""
    if has_flag "--approve" "$@";         then event="APPROVED";        count=$((count+1)); fi
    if has_flag "--request-changes" "$@"; then event="REQUEST_CHANGES"; count=$((count+1)); fi
    if has_flag "--comment" "$@";         then event="COMMENT";         count=$((count+1)); fi

    if [[ $count -eq 0 ]]; then
        echo "Specify exactly one of --approve|--request-changes|--comment" >&2
        exit 1
    fi
    if [[ $count -gt 1 ]]; then
        echo "--approve, --request-changes, --comment are mutually exclusive" >&2
        exit 1
    fi

    local body_text=""
    body_text=$(get_flag "--body" "$@" 2>/dev/null) || body_text=""

    if [[ "$event" == "REQUEST_CHANGES" && -z "$body_text" ]]; then
        echo "--body required with --request-changes" >&2
        exit 1
    fi
    if [[ "$event" == "COMMENT" && -z "$body_text" ]]; then
        echo "--body required with --comment" >&2
        exit 1
    fi

    local body
    if [[ -n "$body_text" ]]; then
        body=$(jq -n --arg e "$event" --arg b "$body_text" '{event: $e, body: $b}')
    else
        body=$(jq -n --arg e "$event" '{event: $e}')
    fi

    # Submit the review under a separate identity when FORGEJO_REVIEW_TOKEN is
    # set. Forgejo forbids approving/rejecting your own PR; when many actors
    # share one token the author and reviewer collapse to the same user, so the
    # review is rejected. The opt-in review token (a distinct account) keeps
    # author != reviewer. Unset -> falls back to FORGEJO_TOKEN (no behaviour change).
    #
    # Use api_call_status (not api_call) so we can intercept a failure and, when
    # the review identity is in play, explain that the 401/403/404 likely comes
    # from THAT account — not FORGEJO_TOKEN. Forgejo returns 404 for private
    # repos a user can't see, so a misconfigured review account looks like a
    # missing PR. Without this hint the error is baffling.
    local out status result
    out=$(FORGEJO_TOKEN="${FORGEJO_REVIEW_TOKEN:-$FORGEJO_TOKEN}" \
        api_call_status POST "repos/$repo/pulls/$number/reviews" "$body")
    status=$(printf '%s' "$out" | head -1)
    result=$(printf '%s' "$out" | tail -n +2)

    if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
        echo "API error ($status):" >&2
        printf '%s\n' "$result" | jq -r '.message // .error // .' >&2 2>/dev/null \
            || printf '%s\n' "$result" >&2
        if [[ -n "${FORGEJO_REVIEW_TOKEN:-}" \
            && ( "$status" == "401" || "$status" == "403" || "$status" == "404" ) ]]; then
            echo "" >&2
            echo "Note: this review was submitted as the FORGEJO_REVIEW_TOKEN identity, not" >&2
            echo "FORGEJO_TOKEN. A $status here usually means that account cannot access" >&2
            echo "$repo (Forgejo returns 404 for repos a user can't see), or its token is" >&2
            echo "missing scopes. Verify the review account is a collaborator/org member on" >&2
            echo "the repo and that its token has read:user + write:repository scopes." >&2
        fi
        exit 1
    fi

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        local rid state
        rid=$(echo "$result" | jq -r .id)
        state=$(echo "$result" | jq -r .state)
        echo "Submitted review #$rid on PR #$number (state: $state)"
    fi
}

