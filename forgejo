user_create() {
    local login email password fullname=""
    local must_change="true"
    local is_admin="false"

    login=$(get_flag "--login" "$@" 2>/dev/null) || { echo "Missing --login" >&2; exit 1; }
    email=$(get_flag "--email" "$@" 2>/dev/null) || { echo "Missing --email" >&2; exit 1; }
    password=$(get_flag "--password" "$@" 2>/dev/null) || { echo "Missing --password" >&2; exit 1; }
    fullname=$(get_flag "--fullname" "$@" 2>/dev/null) || fullname=""
    has_flag "--admin" "$@" && is_admin="true"

    # CreateUserOption has no admin field, so admin cannot be set at creation
    # time. We create the user first, then promote via a follow-up PATCH
    # (the same call `user edit --admin=true` makes).
    local body
    body=$(jq -n \
        --arg login "$login" \
        --arg email "$email" \
        --arg password "$password" \
        --arg fullname "$fullname" \
        --argjson must_change "$must_change" \
        '{
            username: $login,
            email: $email,
            password: $password,
            full_name: $fullname,
            must_change_password: $must_change,
            login_name: $login,
            source_id: 0,
            visibility: "public"
        }')

    local result
    result=$(api_call POST "admin/users" "$body")

    if [[ "$is_admin" == "true" ]]; then
        # Promote in a second call. If this fails, the user still exists —
        # surface the gap loudly rather than reporting a non-admin as admin.
        local promote
        promote=$(jq -n '{login_name: $l, source_id: 0, admin: true}' --arg l "$login")
        if ! api_call PATCH "admin/users/$login" "$promote" > /dev/null 2>&1; then
            echo "User '$login' created, but granting admin failed." >&2
            echo "Retry with: forgejo user edit $login --admin=true" >&2
            exit 1
        fi
    fi

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created user: \(.login) (\(.email))"'
        [[ "$is_admin" == "true" ]] && echo "Granted site admin."
    fi
}

