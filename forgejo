}

# Lists workflow files in the repo. Forgejo's API has no direct endpoint,
# so this reads the repo's .gitea/workflows/ (preferred) or .github/workflows/
# directory via the contents endpoint.
actions_workflow_list() {
    local repo="${1:-}"
    if [[ -z "$repo" ]]; then
        echo "Usage: forgejo actions workflow list <owner/repo>" >&2
        exit 1
    fi
    local path result items
    for path in ".forgejo/workflows" ".gitea/workflows" ".github/workflows"; do
        result=$(api_call GET "repos/$repo/contents/$path" 2>/dev/null) || continue
        items=$(echo "$result" | jq -r --arg p "$path" '
            map(select(.type == "file" and (.name | test("\\.(yml|yaml)$")))) |
            if length == 0 then empty
            else .[] | "\(.name)\t\($p)/\(.name)" end
        ')
        if [[ -n "$items" ]]; then
            if [[ "$JSON_OUTPUT" -eq 1 ]]; then
                echo "$result" | jq '[.[] | select(.type == "file" and (.name | test("\\.(yml|yaml)$"))) | {name, path}]'
            else
                { printf 'NAME\tPATH\n'; echo "$items"; } | column -t -s $'\t'
            fi
            return 0
        fi
    done
    echo "No workflows found in .forgejo/workflows, .gitea/workflows or .github/workflows of $repo" >&2
    exit 1
}

actions_workflow_dispatch() {
    local repo="${1:-}"
    local workflow ref
    workflow=$(get_flag "--workflow" "$@" 2>/dev/null) || workflow=""
    ref=$(get_flag "--ref" "$@" 2>/dev/null) || ref=""
    if [[ -z "$repo" || -z "$workflow" || -z "$ref" ]]; then
        echo "Usage: forgejo actions workflow dispatch <owner/repo> --workflow=X --ref=Y [--input=k=v]..." >&2
        exit 1
    fi
    local inputs_json="{}" arg
    for arg in "$@"; do
        if [[ "$arg" == --input=* ]]; then
            local kv="${arg#--input=}"
            local k="${kv%%=*}"
            local v="${kv#*=}"
            if [[ "$k" == "$kv" ]]; then
                echo "Invalid --input (expected k=v): $arg" >&2
                exit 1
            fi
            inputs_json=$(echo "$inputs_json" | jq --arg k "$k" --arg v "$v" '. + {($k): $v}')
        fi
    done
    local body
    body=$(jq -n --arg ref "$ref" --argjson inputs "$inputs_json" '{ref:$ref, inputs:$inputs}')
    api_call POST "repos/$repo/actions/workflows/$workflow/dispatches" "$body" >/dev/null
    echo "Dispatched $workflow on $ref"
}

cmd_actions_secret() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo actions secret <list|set|delete> [args]" >&2
        exit 1
    fi
    local sub="$1"; shift
    case "$sub" in
        list)   actions_secret_list "$@" ;;
        set)    actions_secret_set "$@" ;;
        delete) actions_secret_delete "$@" ;;
        *) echo "Unknown actions secret command: $sub" >&2; exit 1 ;;
    esac
}

actions_secret_list() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local result
    result=$(api_call GET "$scope/secrets")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            . // [] |
            (["NAME","CREATED"] | @tsv),
            (.[] | [
                (.name // "-"),
                ((.created_at // "-") | if . != "-" then .[:19] else . end)
            ] | @tsv)
        ' | column -t -s $'\t'
    fi
}

actions_secret_set() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local name value
    name=$(get_flag "--name" "$@" 2>/dev/null) || name=""
    value=$(get_flag "--value" "$@" 2>/dev/null) || value=""
    if [[ -z "$name" || -z "$value" ]]; then
        echo "Usage: forgejo actions secret set <owner/repo|org> --name=X --value=X" >&2
        exit 1
    fi
    local body
    body=$(jq -n --arg v "$value" '{data:$v}')
    local out status
    out=$(api_call_status PUT "$scope/secrets/$name" "$body")
    status=$(echo "$out" | head -1)
    if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
        echo "Failed to set secret (HTTP $status):" >&2
        echo "$out" | tail -n +2 >&2
        exit 1
    fi
    echo "Set secret $name"
}

actions_secret_delete() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local rest=()
    mapfile -t rest < <(actions_scope_skip_args "$@")
    local name="${rest[0]:-}"
    if [[ -z "$name" ]]; then
        echo "Usage: forgejo actions secret delete <owner/repo|org> <name> [--yes]" >&2
        exit 1
    fi
    confirm_delete "secret" "$name" "$@"
    api_call DELETE "$scope/secrets/$name" >/dev/null
    echo "Deleted secret $name"
}

cmd_actions_variable() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo actions variable <list|set|delete> [args]" >&2
        exit 1
    fi
    local sub="$1"; shift
    case "$sub" in
        list)   actions_variable_list "$@" ;;
        set)    actions_variable_set "$@" ;;
        delete) actions_variable_delete "$@" ;;
        *) echo "Unknown actions variable command: $sub" >&2; exit 1 ;;
    esac
}

actions_variable_list() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local result
    result=$(api_call GET "$scope/variables")
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            . // [] |
            (["NAME","VALUE"] | @tsv),
            (.[] | [
                (.name // "-"),
                (.data // "-")
            ] | @tsv)
        ' | column -t -s $'\t'
    fi
}

# Idempotent set: GET first to decide POST (create) vs PUT (update). The
# create body field is "value"; update body uses "value" too. The response
# uses "data" for the same field.
actions_variable_set() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local name value
    name=$(get_flag "--name" "$@" 2>/dev/null) || name=""
    value=$(get_flag "--value" "$@" 2>/dev/null) || value=""
    if [[ -z "$name" || -z "$value" ]]; then
        echo "Usage: forgejo actions variable set <owner/repo|org> --name=X --value=X" >&2
        exit 1
    fi
    local body
    body=$(jq -n --arg v "$value" '{value:$v}')
    local probe status
    probe=$(api_call_status GET "$scope/variables/$name")
    status=$(echo "$probe" | head -1)
    local out write_status
    if [[ "$status" -ge 200 && "$status" -lt 300 ]]; then
        out=$(api_call_status PUT "$scope/variables/$name" "$body")
        write_status=$(echo "$out" | head -1)
        if [[ "$write_status" -lt 200 || "$write_status" -ge 300 ]]; then
            echo "Failed to update variable (HTTP $write_status):" >&2
            echo "$out" | tail -n +2 >&2
            exit 1
        fi
        echo "Updated variable $name"
    else
        out=$(api_call_status POST "$scope/variables/$name" "$body")
        write_status=$(echo "$out" | head -1)
        if [[ "$write_status" -lt 200 || "$write_status" -ge 300 ]]; then
            echo "Failed to create variable (HTTP $write_status):" >&2
            echo "$out" | tail -n +2 >&2
            exit 1
        fi
        echo "Created variable $name"
    fi
}

actions_variable_delete() {
    local scope
    scope=$(actions_scope_path "$@") || exit 1
    local rest=()
    mapfile -t rest < <(actions_scope_skip_args "$@")
    local name="${rest[0]:-}"
    if [[ -z "$name" ]]; then
        echo "Usage: forgejo actions variable delete <owner/repo|org> <name> [--yes]" >&2
        exit 1
    fi
    confirm_delete "variable" "$name" "$@"
    api_call DELETE "$scope/variables/$name" >/dev/null
    echo "Deleted variable $name"
}

# --- PR COMMANDS ---

cmd_pr() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_pr_help
        exit 0
    fi

    local action="$1"
    shift

    case "$action" in
        list)   pr_list "$@" ;;
        create) pr_create "$@" ;;
        view)   pr_view "$@" ;;
        merge)  pr_merge "$@" ;;
        close)                pr_close "$@" ;;
        edit)                 pr_edit "$@" ;;
        ready)                pr_ready "$@" ;;
        comment)              pr_comment "$@" ;;
        diff)                 pr_diff "$@" ;;
        files)                pr_files "$@" ;;
        checks)               pr_checks "$@" ;;
        review)               pr_review "$@" ;;
        requested-reviewers)  pr_requested_reviewers "$@" ;;
        *)      echo "Unknown pr action: $action" >&2; exit 1 ;;
    esac
}

pr_list() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo pr list <owner/repo> [--state=open|closed|all]" >&2
        exit 1
    fi

    local repo="$1"
    shift
    local state
    state=$(get_flag "--state" "$@" 2>/dev/null) || state="open"

    local result
    result=$(api_call GET "repos/$repo/pulls?state=$state&limit=50")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        if echo "$result" | jq -e 'length == 0' > /dev/null 2>&1; then
            echo "No pull requests found."
        else
            echo "$result" | jq -r '
                ["#","TITLE","STATE","AUTHOR","BASE","HEAD","UPDATED"],
                (.[] | [
                    (.number|tostring),
                    .title[:50],
                    .state,
                    .user.login,
                    .base.ref,
                    .head.ref,
                    .updated_at[:10]
                ])
                | @tsv
            ' | column -t -s $'\t'
        fi
    fi
}

pr_create() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: forgejo pr create <owner/repo> --title=X --head=X [--base=main] [--body=X]" >&2
        exit 1
    fi

    local repo="$1"
    shift

    local title head base body_text
    title=$(get_flag "--title" "$@" 2>/dev/null) || { echo "Missing --title" >&2; exit 1; }
    head=$(get_flag "--head" "$@" 2>/dev/null) || { echo "Missing --head" >&2; exit 1; }
    base=$(get_flag "--base" "$@" 2>/dev/null) || base="main"
    body_text=$(get_flag "--body" "$@" 2>/dev/null) || body_text=""

    local body
    body=$(jq -n \
        --arg title "$title" \
        --arg head "$head" \
        --arg base "$base" \
        --arg body "$body_text" \
        '{title: $title, head: $head, base: $base, body: $body}')

    local result
    result=$(api_call POST "repos/$repo/pulls" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Created PR #\(.number): \(.title)\nURL: \(.html_url)"'
    fi
}

pr_view() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr view <owner/repo> <number>" >&2
        exit 1
    fi

    local repo="$1"
    local number="$2"

    local result
    result=$(api_call GET "repos/$repo/pulls/$number")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '
            "#\(.number): \(.title)",
            "State:      \(.state)",
            "Author:     \(.user.login)",
            "Base:       \(.base.ref) ← Head: \(.head.ref)",
            "Mergeable:  \(.mergeable // "-")",
            "Created:    \(.created_at[:10])",
            "Updated:    \(.updated_at[:10])",
            "Labels:     \(if (.labels | length) > 0 then ([.labels[].name] | join(", ")) else "-" end)",
            "",
            (.body // "(no body)")
        '

        echo ""
        echo "--- Reviews ---"
        local reviews
        reviews=$(api_call GET "repos/$repo/pulls/$number/reviews")
        echo "$reviews" | jq -r '
            if length == 0 then "No reviews."
            else .[] | "  \(.user.login): \(.state) (\(.submitted_at[:10] // "-"))"
            end
        '
    fi
}

pr_merge() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr merge <owner/repo> <number> [--method=merge|rebase|squash]" >&2
        exit 1
    fi

    local repo="$1"
    local number="$2"
    shift 2

    local method
    method=$(get_flag "--method" "$@" 2>/dev/null) || method="merge"

    local body
    body=$(jq -n --arg method "$method" '{Do: $method}')

    local result
    result=$(api_call POST "repos/$repo/pulls/$number/merge" "$body")

    echo "Merged PR #$number (method: $method)"
}

pr_close() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr close <owner/repo> <number>" >&2
        exit 1
    fi
    local repo="$1"
    local number="$2"

    local body
    body=$(jq -n '{state: "closed"}')
    api_call PATCH "repos/$repo/pulls/$number" "$body" > /dev/null
    echo "Closed PR #$number"
}

pr_edit() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr edit <owner/repo> <number> [--title=X] [--body=X] [--base=X]" >&2
        exit 1
    fi
    local repo="$1"
    local number="$2"
    shift 2

    local body="{}"
    local val

    if val=$(get_flag "--title" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {title: $v}')
    fi
    if val=$(get_flag "--body" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {body: $v}')
    fi
    if val=$(get_flag "--base" "$@" 2>/dev/null); then
        body=$(echo "$body" | jq --arg v "$val" '. + {base: $v}')
    fi

    if [[ "$body" == "{}" ]]; then
        echo "No fields to update. Provide --title, --body, or --base." >&2
        exit 1
    fi

    local result
    result=$(api_call PATCH "repos/$repo/pulls/$number" "$body")

    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
        echo "$result" | jq .
    else
        echo "$result" | jq -r '"Updated PR #\(.number): \(.title)"'
    fi
}

pr_ready() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: forgejo pr ready <owner/repo> <number>" >&2
        exit 1
    fi
    local repo="$1"
    local number="$2"

    # EditPullRequestOption has no `draft` field, so PATCH {draft:false} was
    # silently dropped. Forgejo derives draft state from a WIP title prefix;
    # clearing draft means stripping that prefix from the title.
    local pr title is_draft
    pr=$(api_call GET "repos/$repo/pulls/$number")
    is_draft=$(echo "$pr" | jq -r '.draft')
    title=$(echo "$pr" | jq -r '.title')

    if [[ "$is_draft" != "true" ]]; then
        echo "PR #$number is not a draft; nothing to do." >&2
        exit 1
    fi

    # Strip a leading WIP prefix (Forgejo defaults: "WIP:", "[WIP]"),
    # case-insensitive, along with following whitespace.
    local new_title
    new_title=$(echo "$title" | sed -E 's/^[[:space:]]*(\[WIP\]|WIP:)[[:space:]]*//I')

    if [[ "$new_title" == "$title" ]]; then
        # Draft, but the prefix isn't one we recognise — likely a custom
        # work_in_progress_prefix on this instance. Point at the real fix.
        echo "PR #$number is a draft but its title has no recognised WIP prefix" >&2
        echo "(this instance may use a custom prefix). Remove it manually:" >&2
        echo "  forgejo pr edit $repo $number --title=\"<title without WIP prefix>\"" >&2
        exit 1
    fi

    api_call PATCH "repos/$repo/pulls/$number" \
        "$(jq -n --arg t "$new_title" '{title: $t}')" > /dev/null
    echo "Marked PR #$number ready for review"
}

pr_comment() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_pr_comment_help
        exit 0
    fi

    case "$1" in
